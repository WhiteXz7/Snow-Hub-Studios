function E.findRootPart(tgt)
    if not tgt then return nil end
    
    -- Priority order for root
    local rootNames = {"HumanoidRootPart", "Torso", "UpperTorso", "Root", "RootPart", "Base", "Body"}
    
    for _, name in ipairs(rootNames) do
        local found = tgt:FindFirstChild(name, true)
        if found and found:IsA("BasePart") then
            return found
        end
    end
    
    -- If no named root, find the largest part
    local largest = nil
    local largestSize = 0
    
    pcall(function()
        for _, c in ipairs(tgt:GetDescendants()) do
            if c:IsA("BasePart") and not c:IsA("Terrain") then
                local size = c.Size.X * c.Size.Y * c.Size.Z
                if size > largestSize then
                    largestSize = size
                    largest = c
                end
            end
        end
    end)
    
    return largest or (tgt:IsA("BasePart") and tgt or nil)
end

function E.getPartHierarchy(tgt)
    local parts = {}
    local rootPart = E.findRootPart(tgt)
    
    if not rootPart then return parts end
    
    pcall(function()
        -- Add root first
        table.insert(parts, {part = rootPart, parent = nil, depth = 0})
        
        -- Get all other parts
        local otherParts = {}
        for _, c in ipairs(tgt:GetDescendants()) do
            if c:IsA("BasePart") and not c:IsA("Terrain") and c ~= rootPart then
                table.insert(otherParts, c)
            end
        end
        
        -- Sort by distance from root (creates natural hierarchy)
        table.sort(otherParts, function(a, b)
            return (a.Position - rootPart.Position).Magnitude < (b.Position - rootPart.Position).Magnitude
        end)
        
        -- Build hierarchy based on proximity
        for _, part in ipairs(otherParts) do
            local closestParent = rootPart
            local closestDist = (part.Position - rootPart.Position).Magnitude
            
            -- Find closest already-added part
            for _, entry in ipairs(parts) do
                local dist = (part.Position - entry.part.Position).Magnitude
                if dist < closestDist and dist > 0.01 then
                    closestDist = dist
                    closestParent = entry.part
                end
            end
            
            local parentDepth = 0
            for _, entry in ipairs(parts) do
                if entry.part == closestParent then
                    parentDepth = entry.depth
                    break
                end
            end
            
            table.insert(parts, {part = part, parent = closestParent, depth = parentDepth + 1})
        end
    end)
    
    return parts
end

function E.createMotors(tgt)
    if not tgt then return 0 end
    
    print("[Snow] 🦴 Creating professional rig...")
    
    local hierarchy = E.getPartHierarchy(tgt)
    local created = 0
    
    for _, entry in ipairs(hierarchy) do
        if entry.parent then
            -- Check if motor already exists
            local hasMotor = false
            pcall(function()
                for _, child in ipairs(entry.parent:GetChildren()) do
                    if child:IsA("Motor6D") and child.Part1 == entry.part then
                        hasMotor = true
                        break
                    end
                end
                for _, child in ipairs(entry.part:GetChildren()) do
                    if child:IsA("Motor6D") and child.Part1 == entry.part then
                        hasMotor = true
                        break
                    end
                end
            end)
            
            if not hasMotor then
                pcall(function()
                    local motor = Instance.new("Motor6D")
                    motor.Name = "Snow_" .. entry.part.Name
                    motor.Part0 = entry.parent
                    motor.Part1 = entry.part
                    
                    -- Calculate proper C0 and C1 for natural joint position
                    local jointPos = (entry.parent.Position + entry.part.Position) / 2
                    motor.C0 = entry.parent.CFrame:ToObjectSpace(CFrame.new(jointPos))
                    motor.C1 = entry.part.CFrame:ToObjectSpace(CFrame.new(jointPos))
                    
                    motor.Parent = entry.parent
                    created = created + 1
                    
                    print("[Snow]   + " .. entry.parent.Name .. " → " .. entry.part.Name)
                end)
            end
        end
    end
    
    print("[Snow] ✅ Created " .. created .. " Motor6D joints")
    return created
end

function E.removeMotors(tgt)
    if not tgt then return 0 end
    
    local removed = 0
    pcall(function()
        for _, c in ipairs(tgt:GetDescendants()) do
            if c:IsA("Motor6D") and c.Name:sub(1, 5) == "Snow_" then
                c:Destroy()
                removed = removed + 1
            end
        end
    end)
    
    print("[Snow] 🗑️ Removed " .. removed .. " auto-created motors")
    return removed
end

function E.hasMotors(tgt)
    if not tgt then return false end
    local found = false
    pcall(function()
        for _, c in ipairs(tgt:GetDescendants()) do
            if c:IsA("Motor6D") then
                found = true
                break
            end
        end
    end)
    return found
end

-- ══════════════════════════════════════
-- SCANNING (Detects all animatable objects)
-- ══════════════════════════════════════

function E.scan(tgt)
    E.joints = {}
    E.target = tgt
    
    if not tgt then
        print("[Snow] ❌ No target provided")
        return
    end
    
    print("[Snow] 🔍 Scanning: " .. tgt.Name .. " (" .. tgt.ClassName .. ")")
    
    local descendants = {}
    pcall(function()
        descendants = tgt:GetDescendants()
    end)
    
    -- Count parts
    local partCount = 0
    for _, c in ipairs(descendants) do
        if c:IsA("BasePart") and not c:IsA("Terrain") then
            partCount = partCount + 1
        end
    end
    if tgt:IsA("BasePart") then partCount = partCount + 1 end
    
    -- ═══ PRO MODE: Auto-create Motor6D if needed ═══
    if E.proMode and partCount >= 2 and not E.hasMotors(tgt) then
        print("[Snow] 🦴 Pro Mode: Creating Motor6D rig...")
        E.createMotors(tgt)
        -- Refresh descendants
        pcall(function()
            descendants = tgt:GetDescendants()
        end)
    end
    
    -- ═══ 1. MOTOR6D (Best quality) ═══
    local motorParts = {}
    for _, c in ipairs(descendants) do
        pcall(function()
            if c:IsA("Motor6D") and c.Part0 and c.Part1 then
                table.insert(E.joints, {
                    t = "m6d",
                    inst = c,
                    name = c.Name,
                    origC0 = c.C0,
                    origC1 = c.C1,
                    part0 = c.Part0,
                    part1 = c.Part1
                })
                motorParts[c.Part0] = true
                motorParts[c.Part1] = true
            end
        end)
    end
    
    -- ═══ 2. BONES (R15/Skinned meshes) ═══
    for _, c in ipairs(descendants) do
        pcall(function()
            if c:IsA("Bone") then
                table.insert(E.joints, {
                    t = "bone",
                    inst = c,
                    name = "Bone_" .. c.Name,
                    origCF = c.CFrame,
                    origTrans = c.Transform
                })
            end
        end)
    end
    
    -- ═══ 3. PARTS (Fallback for non-rigged) ═══
    if #E.joints == 0 or not E.proMode then
        if tgt:IsA("BasePart") and not E.isLocalChar(tgt) and not motorParts[tgt] then
            table.insert(E.joints, {
                t = "part",
                inst = tgt,
                name = tgt.Name,
                origCF = tgt.CFrame,
                origSize = tgt.Size,
                origColor = tgt.Color,
                origTrans = tgt.Transparency
            })
        end
        
        for i, c in ipairs(descendants) do
            pcall(function()
                if c:IsA("BasePart") and not c:IsA("Terrain") and not E.isLocalChar(c) and not motorParts[c] then
                    local pName = c.Name
                    local count = 0
                    for _, j in ipairs(E.joints) do
                        if j.name == pName or j.name:match("^" .. pName .. "_%d+$") then
                            count = count + 1
                        end
                    end
                    if count > 0 then pName = c.Name .. "_" .. count end
                    
                    table.insert(E.joints, {
                        t = "part",
                        inst = c,
                        name = pName,
                        origCF = c.CFrame,
                        origSize = c.Size,
                        origColor = c.Color,
                        origTrans = c.Transparency
                    })
                end
            end)
        end
    end
    
    -- ═══ 4. GUI ═══
    for _, c in ipairs(descendants) do
        pcall(function()
            if c:IsA("GuiObject") then
                table.insert(E.joints, {
                    t = "gui",
                    inst = c,
                    name = c.Name .. "_gui",
                    oP = c.Position,
                    oS = c.Size,
                    oR = c.Rotation,
                    oT = c.BackgroundTransparency,
                    oC = c.BackgroundColor3
                })
            end
        end)
    end
    
    -- ═══ 5. LIGHTS ═══
    for _, c in ipairs(descendants) do
        pcall(function()
            if c:IsA("Light") then
                table.insert(E.joints, {
                    t = "light",
                    inst = c,
                    name = c.Name .. "_light",
                    origBright = c.Brightness,
                    origColor = c.Color,
                    origEnabled = c.Enabled,
                    origRange = c:IsA("PointLight") and c.Range or nil,
                    origAngle = c:IsA("SpotLight") and c.Angle or nil
                })
            end
        end)
    end
    
    -- ═══ 6. PARTICLES ═══
    for _, c in ipairs(descendants) do
        pcall(function()
            if c:IsA("ParticleEmitter") then
                table.insert(E.joints, {
                    t = "particle",
                    inst = c,
                    name = c.Name .. "_particle",
                    origEnabled = c.Enabled,
                    origRate = c.Rate,
                    origSpeed = c.Speed,
                    origSize = c.Size,
                    origTrans = c.Transparency,
                    origLife = c.Lifetime
                })
            elseif c:IsA("Beam") then
                table.insert(E.joints, {
                    t = "beam",
                    inst = c,
                    name = c.Name .. "_beam",
                    origEnabled = c.Enabled,
                    origWidth0 = c.Width0,
                    origWidth1 = c.Width1,
                    origColor = c.Color
                })
            elseif c:IsA("Trail") then
                table.insert(E.joints, {
                    t = "trail",
                    inst = c,
                    name = c.Name .. "_trail",
                    origEnabled = c.Enabled,
                    origLife = c.Lifetime,
                    origWidth = c.WidthScale
                })
            end
        end)
    end
    
    -- ═══ 7. SOUNDS ═══
    for _, c in ipairs(descendants) do
        pcall(function()
            if c:IsA("Sound") then
                table.insert(E.joints, {
                    t = "sound",
                    inst = c,
                    name = c.Name .. "_sound",
                    origVol = c.Volume,
                    origPitch = c.PlaybackSpeed,
                    origPlaying = c.Playing
                })
            end
        end)
    end
    
    -- ═══ 8. MESH DEFORMATION ═══
    for _, c in ipairs(descendants) do
        pcall(function()
            if c:IsA("SpecialMesh") or c:IsA("BlockMesh") or c:IsA("CylinderMesh") then
                table.insert(E.joints, {
                    t = "mesh",
                    inst = c,
                    name = c.Name .. "_mesh",
                    origScale = c.Scale,
                    origOffset = c.Offset
                })
            end
        end)
    end
    
    print("[Snow] ✅ Found " .. #E.joints .. " animatable objects:")
    
    -- Summary by type
    local counts = {}
    for _, j in ipairs(E.joints) do
        counts[j.t] = (counts[j.t] or 0) + 1
    end
    for t, c in pairs(counts) do
        print("[Snow]   • " .. t .. ": " .. c)
    end
    
    pcall(S.updJ)
end

