local S = _G.S
local E = S.E

-- TWEEN MODE (animação sem keyframes)
E.twMode=false
E.twDur=1
E.twStyle="Quad"
E.twDir="InOut"
E.twLoop=false
E.twRev=false
E.twStart=nil
E.twEnd=nil

function E.twCapStart() E.twStart=E.snap() end
function E.twCapEnd() E.twEnd=E.snap() end

function E.twPlay()
    if not E.twStart or not E.twEnd then return end
    if E.conn then pcall(function() E.conn:Disconnect() end) E.conn=nil end
    E.playing=true
    local st=tick()
    E.conn=S.RS.Heartbeat:Connect(function()
        if not E.playing then
            pcall(function() if E.conn then E.conn:Disconnect() E.conn=nil end end) return
        end
        local el=tick()-st
        local raw=el/E.twDur
        if E.twRev then
            local phase=(el%(E.twDur*2))/E.twDur
            raw = phase>1 and (2-phase) or phase
            if not E.twLoop and el>=E.twDur*2 then
                E.playing=false pcall(function() if E.conn then E.conn:Disconnect() E.conn=nil end end) raw=0
            end
            if E.twLoop and el>=E.twDur*2 then st=tick() end
        else
            if raw>=1 then
                if E.twLoop then st=tick() raw=0
                else raw=1 E.playing=false pcall(function() if E.conn then E.conn:Disconnect() E.conn=nil end end) end
            end
        end
        raw=math.clamp(raw,0,1)
        local ea=E.ease(raw,E.twStyle,E.twDir)
        local result={}
        local all={} for k in pairs(E.twStart) do all[k]=true end for k in pairs(E.twEnd) do all[k]=true end
        for k in pairs(all) do
            local a,b=E.twStart[k],E.twEnd[k]
            if a and not b then result[k]=a elseif b and not a then result[k]=b
            elseif a and b then
                local r={}
                if a.cf and b.cf then r.cf=E.lCF(a.cf,b.cf,ea) end
                if a.sz and b.sz then
                    if typeof(a.sz)=="Vector3" then r.sz=E.lV3(a.sz,b.sz,ea)
                    elseif typeof(a.sz)=="UDim2" then r.sz=E.lU2(a.sz,b.sz,ea) end
                end
                if a.tr~=nil and b.tr~=nil then r.tr=E.lN(a.tr,b.tr,ea) end
                if a.cl and b.cl then r.cl=E.lC3(a.cl,b.cl,ea) end
                if a.pos and b.pos then r.pos=E.lU2(a.pos,b.pos,ea) end
                if a.rot~=nil and b.rot~=nil then r.rot=E.lN(a.rot,b.rot,ea) end
                result[k]=r
            end
        end
        E.apply(result)
    end)
end

function E.twToKF()
    if not E.twStart or not E.twEnd then return end
    E.pushU() E.kfs={}
    local jc1={} for k,v in pairs(E.twStart) do local vc={} for kk,vv in pairs(v) do vc[kk]=vv end jc1[k]=vc end
    local jc2={} for k,v in pairs(E.twEnd) do local vc={} for kk,vv in pairs(v) do vc[kk]=vv end jc2[k]=vc end
    table.insert(E.kfs,{t=0,j=jc1}) table.insert(E.kfs,{t=E.twDur,j=jc2})
end

-- SERIALIZE
function E.serialize()
    local d={k={},s=E.speed,l=E.looping,at=E.animType,im=E.interp}
    for i,kf in ipairs(E.kfs) do
        local jd={}
        for jn,v in pairs(kf.j) do
            local vv={es=v.es,ed=v.ed}
            if v.cf then pcall(function() vv.cf={v.cf:GetComponents()} end) end
            if v.sz and typeof(v.sz)=="Vector3" then vv.sz={v.sz.X,v.sz.Y,v.sz.Z} end
            if v.tr~=nil then vv.tr=v.tr end
            if v.cl then vv.cl={v.cl.R,v.cl.G,v.cl.B} end
            if v.pos then pcall(function() vv.pos={v.pos.X.Scale,v.pos.X.Offset,v.pos.Y.Scale,v.pos.Y.Offset} end) end
            if v.rot then vv.rot=v.rot end
            jd[jn]=vv
        end
        d.k[i]={t=kf.t,j=jd}
    end
    return d
end

function E.deserialize(d)
    if not d or not d.k then return end
    E.speed=d.s or 1 E.looping=d.l or false E.animType=d.at or "Action1" E.interp=d.im or "Linear"
    E.kfs={}
    for i,kd in ipairs(d.k) do
        local jd={}
        for jn,v in pairs(kd.j) do
            local vv={es=v.es,ed=v.ed}
            if v.cf then pcall(function() vv.cf=CFrame.new(unpack(v.cf)) end) end
            if v.sz then pcall(function() vv.sz=Vector3.new(unpack(v.sz)) end) end
            if v.tr~=nil then vv.tr=v.tr end
            if v.cl then pcall(function() vv.cl=Color3.new(unpack(v.cl)) end) end
            if v.pos then pcall(function() vv.pos=UDim2.new(unpack(v.pos)) end) end
            if v.rot then vv.rot=v.rot end
            jd[jn]=vv
        end
        E.kfs[i]={t=kd.t,j=jd}
    end
end

-- EXPORT SCRIPT
function E.genScript(exportType)
    local header = "-- Snow Animator Pro❄️ Export\n-- Type: "..(exportType or "NPC").."\n-- Animation: "..E.animType.."\n\n"
    local instructions = ""
    if exportType=="Player" then
        instructions = "-- INSTRUCTIONS: Place this Script inside StarterCharacterScripts\n-- It will auto-play when the player spawns\n\n"
    elseif exportType=="NPC" then
        instructions = "-- INSTRUCTIONS: Place this Script inside the NPC Model\n-- The NPC must have Motor6D joints (Humanoid rig)\n\n"
    elseif exportType=="Tool" then
        instructions = "-- INSTRUCTIONS: Place this LocalScript inside the Tool\n-- Animation plays when tool is equipped\n\n"
    elseif exportType=="Object" then
        instructions = "-- INSTRUCTIONS: Place this Script inside the Part/Model\n-- Animation plays on server start\n\n"
    elseif exportType=="Gui" then
        instructions = "-- INSTRUCTIONS: Place this LocalScript inside the ScreenGui\n-- Animates GUI elements\n\n"
    elseif exportType=="Effect" then
        instructions = "-- INSTRUCTIONS: Place this Script inside the effect parent\n-- Controls particle/light properties over time\n\n"
    end

    local s = header..instructions
    s=s.."local RunService=game:GetService('RunService')\n"
    s=s.."local speed="..E.speed.."\nlocal looping="..tostring(E.looping).."\n"
    s=s.."local keyframes={\n"
    for _,kf in ipairs(E.kfs) do
        s=s.."  {t="..string.format("%.4f",kf.t)..",j={\n"
        for jn,d in pairs(kf.j) do
            s=s..'    ["'..jn..'"]={'
            if d.cf then pcall(function()
                local c={d.cf:GetComponents()}
                local cs={} for _,v in ipairs(c) do table.insert(cs,string.format("%.6f",v)) end
                s=s.."cf=CFrame.new("..table.concat(cs,",").."),"
            end) end
            s=s.."},\n"
        end
        s=s.."  }},\n"
    end
    s=s.."}\n\n"
    s=s..[[local target=script.Parent
local joints={}
for _,d in ipairs(target:GetDescendants()) do
  if d:IsA("Motor6D") then joints[d.Name]=d end
end

local startTime=tick()
local maxTime=0
for _,k in ipairs(keyframes) do if k.t>maxTime then maxTime=k.t end end

RunService.Heartbeat:Connect(function()
  local elapsed=(tick()-startTime)*speed
  if elapsed>maxTime then
    if looping then startTime=tick() elapsed=0
    else return end
  end
  local prev,nxt
  for _,k in ipairs(keyframes) do
    if k.t<=elapsed then prev=k end
    if k.t>=elapsed and not nxt then nxt=k end
  end
  if prev and nxt and prev~=nxt then
    local alpha=math.clamp((elapsed-prev.t)/(nxt.t-prev.t),0,1)
    for jointName,prevData in pairs(prev.j) do
      local nxtData=nxt.j[jointName]
      if nxtData and joints[jointName] and prevData.cf and nxtData.cf then
        joints[jointName].C0=prevData.cf:Lerp(nxtData.cf,alpha)
      end
    end
  end
end)
]]
    return s
end

-- EXPORT TO REPLICATED STORAGE
function E.exportRS(typ)
    E.expCount=E.expCount+1
    local fn="SNA_"..string.format("%03d",E.expCount)
    pcall(function()
        local f=Instance.new("Folder") f.Name=fn f.Parent=S.Rep
        Instance.new("StringValue",f).Name="Type" f.Type.Value=typ or "NPC"
        Instance.new("StringValue",f).Name="AnimType" f.AnimType.Value=E.animType
        Instance.new("NumberValue",f).Name="Speed" f.Speed.Value=E.speed
        Instance.new("BoolValue",f).Name="Loop" f.Loop.Value=E.looping
        local kff=Instance.new("Folder",f) kff.Name="KeyFrames"
        for i,kf in ipairs(E.kfs) do
            local ki=Instance.new("Folder",kff) ki.Name="KF"..i
            Instance.new("NumberValue",ki).Name="Time" ki.Time.Value=kf.t
            for jn,d in pairs(kf.j) do
                if d.cf then pcall(function()
                    local cv=Instance.new("CFrameValue",ki) cv.Name=jn cv.Value=d.cf
                end) end
            end
        end
        local ps=Instance.new("ModuleScript",f) ps.Name="PlaybackScript" ps.Source=E.genScript(typ)
    end)
    return fn
end

