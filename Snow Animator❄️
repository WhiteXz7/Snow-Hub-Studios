-- ══════════════════════════════════════
-- EASING FUNCTIONS (Professional)
-- ══════════════════════════════════════

function E.bounce(t)
    if t < 1/2.75 then return 7.5625*t*t
    elseif t < 2/2.75 then t = t - 1.5/2.75 return 7.5625*t*t + 0.75
    elseif t < 2.5/2.75 then t = t - 2.25/2.75 return 7.5625*t*t + 0.9375
    else t = t - 2.625/2.75 return 7.5625*t*t + 0.984375 end
end

function E.spring(t, amplitude, frequency)
    amplitude = amplitude or 1
    frequency = frequency or 3
    return 1 - math.exp(-6 * t) * math.cos(frequency * math.pi * 2 * t) * amplitude
end

function E.bezier(t, p1, p2)
    p1 = p1 or 0.25
    p2 = p2 or 0.75
    local u = 1 - t
    return 3 * u * u * t * p1 + 3 * u * t * t * p2 + t * t * t
end

function E.ease(a, s, d)
    if not s or s == "Linear" then return a end
    if s == "Constant" then return a >= 1 and 1 or 0 end
    if s == "Bezier" then return E.bezier(a) end
    if s == "Spring" then return E.spring(a) end
    
    local function ei(t)
        if s == "Quad" then return t*t
        elseif s == "Cubic" then return t*t*t
        elseif s == "Quart" then return t^4
        elseif s == "Quint" then return t^5
        elseif s == "Sine" then return 1 - math.cos(t * math.pi / 2)
        elseif s == "Expo" then return t == 0 and 0 or 2^(10 * (t - 1))
        elseif s == "Circ" then return 1 - math.sqrt(math.max(0, 1 - t*t))
        elseif s == "Back" then return t*t * (2.70158*t - 1.70158)
        elseif s == "Elastic" then
            if t == 0 or t == 1 then return t end
            return -2^(10 * (t - 1)) * math.sin((t - 1.1) * 5 * math.pi)
        elseif s == "Bounce" then return 1 - E.bounce(1 - t)
        end
        return t
    end
    
    local function eo(t)
        if s == "Bounce" then return E.bounce(t) end
        return 1 - ei(1 - t)
    end
    
    d = d or "InOut"
    if d == "In" then return ei(a)
    elseif d == "Out" then return eo(a)
    else return a < 0.5 and ei(a * 2) / 2 or 0.5 + eo((a - 0.5) * 2) / 2 end
end

-- ══════════════════════════════════════
-- LERP FUNCTIONS (Smooth Interpolation)
-- ══════════════════════════════════════

function E.lCF(a, b, t)
    -- Spherical interpolation for smoother rotation
    local ok, r = pcall(function()
        return a:Lerp(b, t)
    end)
    return ok and r or a
end

function E.lV3(a, b, t)
    local ok, r = pcall(function()
        return a:Lerp(b, t)
    end)
    return ok and r or a
end

function E.lN(a, b, t)
    return a + (b - a) * t
end

function E.lC3(a, b, t)
    -- HSV interpolation for better color blending
    local h1, s1, v1 = Color3.toHSV(a)
    local h2, s2, v2 = Color3.toHSV(b)
    
    -- Handle hue wrapping
    if math.abs(h2 - h1) > 0.5 then
        if h1 > h2 then h2 = h2 + 1
        else h1 = h1 + 1 end
    end
    
    local h = (h1 + (h2 - h1) * t) % 1
    local s = s1 + (s2 - s1) * t
    local v = v1 + (v2 - v1) * t
    
    return Color3.fromHSV(h, s, v)
end

function E.lU2(a, b, t)
    return UDim2.new(
        a.X.Scale + (b.X.Scale - a.X.Scale) * t,
        a.X.Offset + (b.X.Offset - a.X.Offset) * t,
        a.Y.Scale + (b.Y.Scale - a.Y.Scale) * t,
        a.Y.Offset + (b.Y.Offset - a.Y.Offset) * t
    )
end

-- Catmull-Rom spline for super smooth animation
function E.catmullRom(p0, p1, p2, p3, t)
    local t2 = t * t
    local t3 = t2 * t
    return 0.5 * (
        (2 * p1) +
        (-p0 + p2) * t +
        (2 * p0 - 5 * p1 + 4 * p2 - p3) * t2 +
        (-p0 + 3 * p1 - 3 * p2 + p3) * t3
    )
end

