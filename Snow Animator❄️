function Engine:Serialize()
    local data = {
        KF = {},
        Spd = self.Speed,
        AT = self.AnimType,
        IM = self.InterpMode,
        Loop = self.IsLooping,
        FPS = self.FPS,
        VM = self.ViewMode
    }
    for i, kf in ipairs(self.Keyframes) do
        local kd = {t = kf.time, j = {}}
        for jn, jd in pairs(kf.joints) do
            local d = {ES=jd.ES, ED=jd.ED}
            if jd.CF then
                d.CF = {jd.CF:GetComponents()}
            end
            if jd.SZ then
                if typeof(jd.SZ)=="Vector3" then
                    d.SZ = {jd.SZ.X,jd.SZ.Y,jd.SZ.Z}
                    d.ST = "V3"
                end
            end
            if jd.Sz then
                d.Sz = {
                    jd.Sz.X.Scale,jd.Sz.X.Offset,
                    jd.Sz.Y.Scale,jd.Sz.Y.Offset
                }
            end
            if jd.Pos then
                d.Pos = {
                    jd.Pos.X.Scale,jd.Pos.X.Offset,
                    jd.Pos.Y.Scale,jd.Pos.Y.Offset
                }
            end
            if jd.TR then d.TR = jd.TR end
            if jd.Rot then d.Rot = jd.Rot end
            if jd.Tr then d.Tr = jd.Tr end
            if jd.CL then
                d.CL = {jd.CL.R,jd.CL.G,jd.CL.B}
            end
            if jd.Rate then d.Rate = jd.Rate end
            if jd.Bright then d.Bright=jd.Bright end
            if jd.Range then d.Range=jd.Range end
            kd.j[jn] = d
        end
        data.KF[i] = kd
    end
    return data
end

function Engine:Deserialize(data)
    if not data then return end
    self.Speed = data.Spd or 1
    self.AnimType = data.AT or "Core"
    self.InterpMode = data.IM or "Linear"
    self.IsLooping = data.Loop or false
    self.FPS = data.FPS or 60
    self.ViewMode = data.VM or "Global"
    self.Keyframes = {}
    
    for i, kd in ipairs(data.KF or {}) do
        local kf = {time=kd.t, joints={}}
        for jn, d in pairs(kd.j) do
            local jd = {
                ES = d.ES or "Linear",
                ED = d.ED or "InOut"
            }
            if d.CF then
                jd.CF = CFrame.new(unpack(d.CF))
            end
            if d.SZ then
                if d.ST=="V3" then
                    jd.SZ = Vector3.new(unpack(d.SZ))
                end
            end
            if d.Sz then
                jd.Sz = UDim2.new(unpack(d.Sz))
            end
            if d.Pos then
                jd.Pos = UDim2.new(unpack(d.Pos))
            end
            if d.TR then jd.TR = d.TR end
            if d.Rot then jd.Rot = d.Rot end
            if d.Tr then jd.Tr = d.Tr end
            if d.CL then
                jd.CL = Color3.new(unpack(d.CL))
            end
            if d.Rate then jd.Rate=d.Rate end
            if d.Bright then jd.Bright=d.Bright end
            if d.Range then jd.Range=d.Range end
            kf.joints[jn] = jd
        end
        self.Keyframes[i] = kf
    end
end

