local SaveSystem = {}
SaveSystem.__index = SaveSystem

function SaveSystem.new()
    local self = setmetatable({}, SaveSystem)
    self.Slots = {}
    for i = 1, 10 do
        self.Slots[i] = {
            Name = "",
            Data = nil,
            Exists = false
        }
    end
    self:Load()
    return self
end

function SaveSystem:GetFolder()
    local f = ReplicatedStorage:FindFirstChild("SnowAnimSaves")
    if not f then
        f = Instance.new("Folder")
        f.Name = "SnowAnimSaves"
        f.Parent = ReplicatedStorage
    end
    return f
end

function SaveSystem:Save()
    pcall(function()
        local folder = self:GetFolder()
        for i = 1, 10 do
            local sf = folder:FindFirstChild("S"..i)
            if not sf then
                sf = Instance.new("Folder")
                sf.Name = "S"..i
                sf.Parent = folder
            end
            
            local nv = sf:FindFirstChild("N")
            if not nv then
                nv = Instance.new("StringValue")
                nv.Name = "N"
                nv.Parent = sf
            end
            nv.Value = self.Slots[i].Name or ""
            
            local dv = sf:FindFirstChild("D")
            if not dv then
                dv = Instance.new("StringValue")
                dv.Name = "D"
                dv.Parent = sf
            end
            if self.Slots[i].Data then
                dv.Value = HttpService:JSONEncode(
                    self.Slots[i].Data
                )
            else
                dv.Value = ""
            end
            
            local ev = sf:FindFirstChild("E")
            if not ev then
                ev = Instance.new("BoolValue")
                ev.Name = "E"
                ev.Parent = sf
            end
            ev.Value = self.Slots[i].Exists
        end
    end)
end

function SaveSystem:Load()
    pcall(function()
        local folder = self:GetFolder()
        for i = 1, 10 do
            local sf = folder:FindFirstChild("S"..i)
            if sf then
                local nv = sf:FindFirstChild("N")
                local dv = sf:FindFirstChild("D")
                local ev = sf:FindFirstChild("E")
                if nv then
                    self.Slots[i].Name = nv.Value
                end
                if dv and dv.Value ~= "" then
                    self.Slots[i].Data = 
                        HttpService:JSONDecode(dv.Value)
                end
                if ev then
                    self.Slots[i].Exists = ev.Value
                end
            end
        end
    end)
end

function SaveSystem:SaveSlot(idx, name, data)
    self.Slots[idx] = {
        Name = name,
        Data = data,
        Exists = true
    }
    self:Save()
end

function SaveSystem:DeleteSlot(idx)
    self.Slots[idx] = {
        Name = "",
        Data = nil,
        Exists = false
    }
    self:Save()
end

function SaveSystem:GetSlot(idx)
    return self.Slots[idx]
end

