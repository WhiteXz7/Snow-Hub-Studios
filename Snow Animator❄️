local UI = {}

function UI.Create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then
            pcall(function()
                inst[k] = v
            end)
        end
    end
    if props.Parent then
        inst.Parent = props.Parent
    end
    return inst
end

