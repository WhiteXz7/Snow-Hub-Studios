    local f=N("Frame",{Name=name,Size=UDim2.new(0,w,0,h),Position=UDim2.new(0.5,-w/2,0.5,-h/2),BackgroundColor3=C.bg,Visible=false,ZIndex=50,Parent=S.SG})
