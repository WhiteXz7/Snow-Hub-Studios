S.cePts = {}
function S.drawCurve()
    -- Limpa pontos antigos
    for _,p in ipairs(S.cePts) do 
        pcall(function() p:Destroy() end) 
    end
    S.cePts = {}
    
    -- Verifica se cc existe
    if not cc or not cc.Parent then return end
    
    -- Linha de referência (diagonal)
    for i = 0, 40 do
        local t = i / 40
        local dot = N("Frame", {
            Size = UDim2.new(0, 2, 0, 2),
            Position = UDim2.new(t, -1, 1 - t, -1),
            BackgroundColor3 = Color3.fromRGB(45, 48, 60),
            BorderSizePixel = 0,
            ZIndex = 53,
            Parent = cc
        })
        if dot then table.insert(S.cePts, dot) end
    end
    
    -- Curva de easing
    for i = 0, 60 do
        local t = i / 60
        local eased = E.ease(t, E.interp, E.eDir)
        eased = math.clamp(eased, -0.05, 1.05)
        
        local dot = N("Frame", {
            Size = UDim2.new(0, 4, 0, 4),
            Position = UDim2.new(t, -2, 1 - eased, -2),
            BackgroundColor3 = C.cyan,
            BorderSizePixel = 0,
            ZIndex = 54,
            Parent = cc
        })
        if dot then 
            S.Cn(dot, 2) 
            table.insert(S.cePts, dot) 
        end
    end
    
    -- Ponto inicial (verde)
    local startDot = N("Frame", {
        Size = UDim2.new(0, 8, 0, 8),
        Position = UDim2.new(0, -4, 1, -4),
        BackgroundColor3 = C.green,
        ZIndex = 55,
        Parent = cc
    })
    if startDot then 
        S.Cn(startDot, 4) 
        table.insert(S.cePts, startDot) 
    end
    
    -- Ponto final (vermelho)
    local endEased = E.ease(1, E.interp, E.eDir)
    local endDot = N("Frame", {
        Size = UDim2.new(0, 8, 0, 8),
        Position = UDim2.new(1, -4, 1 - endEased, -4),
        BackgroundColor3 = C.red,
        ZIndex = 55,
        Parent = cc
    })
    if endDot then 
        S.Cn(endDot, 4) 
        table.insert(S.cePts, endDot) 
    end
end

