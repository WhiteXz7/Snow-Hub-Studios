-- Curve drawing
SAP.cePts = {}
function SAP.drawCurve()
    for _,p in ipairs(SAP.cePts) do pcall(function() p:Destroy() end) end
    SAP.cePts = {}

    -- Linear reference line (gray)
    for i=0,40 do
        local t=i/40
        local dot = New("Frame", {Size=UDim2.new(0,2,0,2), Position=UDim2.new(t,-1,1-t,-1), BackgroundColor3=Color3.fromRGB(50,55,70), BorderSizePixel=0, ZIndex=63, Parent=ceCanvas})
        if dot then table.insert(SAP.cePts, dot) end
    end

    -- Actual curve (bright)
    for i=0,80 do
        local t=i/80
        local et=E.ease(t, E.interpMode, E.easingDir)
        et = math.clamp(et, -0.1, 1.1)
        local dot = New("Frame", {Size=UDim2.new(0,3,0,3), Position=UDim2.new(t,-1,1-et,-1), BackgroundColor3=C.cyan, BorderSizePixel=0, ZIndex=64, Parent=ceCanvas})
        if dot then SAP.Corner(dot,2) table.insert(SAP.cePts, dot) end
    end

    -- Control points at start and end
    local startDot = New("Frame", {Size=UDim2.new(0,8,0,8), Position=UDim2.new(0,-4,1,-4), BackgroundColor3=C.green, ZIndex=65, Parent=ceCanvas})
    if startDot then SAP.Corner(startDot,4) table.insert(SAP.cePts, startDot) end
    local endDot = New("Frame", {Size=UDim2.new(0,8,0,8), Position=UDim2.new(1,-4,0,-4), BackgroundColor3=C.red, ZIndex=65, Parent=ceCanvas})
    if endDot then SAP.Corner(endDot,4) table.insert(SAP.cePts, endDot) end
end

