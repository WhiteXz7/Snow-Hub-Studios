-- KEYBOARD SHORTCUTS
UserInputService.InputBegan:Connect(function(inp,gp)
    if gp then return end
    local kc=inp.KeyCode
    if kc==Enum.KeyCode.Space then if Eng.IsPlaying then Eng:Pause() else Eng:Play() end
    elseif kc==Enum.KeyCode.K then Eng:AddKeyframe()
    elseif kc==Enum.KeyCode.Z and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then Eng:Redo() else Eng:Undo() end
    elseif kc==Enum.KeyCode.C and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then Eng:CopyKF()
    elseif kc==Enum.KeyCode.V and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then Eng:PasteKF()
    elseif kc==Enum.KeyCode.Delete then Eng:RemoveKFAt(Eng.CurrentTime)
    elseif kc==Enum.KeyCode.Left then Eng.CurrentTime=math.max(0,Eng.CurrentTime-1/Eng.FPS) Eng:GoTo(Eng.CurrentTime)
    elseif kc==Enum.KeyCode.Right then Eng.CurrentTime=Eng.CurrentTime+1/Eng.FPS Eng:GoTo(Eng.CurrentTime)
    elseif kc==Enum.KeyCode.Home then Eng:GoTo(0)
    elseif kc==Enum.KeyCode.End then Eng:GoTo(Eng:GetMaxTime()) end
end)

