            fbsp=fb.Position
            local st=tick()
            inp.Changed:Connect(function()
                if inp.UserInputState==
                   Enum.UserInputState.End then
                    fbd=false
                    if tick()-st<0.2 then
                        local td=(inp.Position-
                            fbds).Magnitude
                        if td<10 then
                            if Hub.Visible then
                                Hub.Visible=false
                            elseif AF.Visible then
                                AF.Visible=false
                                Hub.Visible=true
                            else
                                Hub.Visible=true
                            end
                        end
                    end
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(
        function(inp)
        if fbd and inp.UserInputType==
           Enum.UserInputType.Touch then
            local d=inp.Position-fbds
            fb.Position=UDim2.new(
                fbsp.X.Scale,fbsp.X.Offset+d.X,
                fbsp.Y.Scale,fbsp.Y.Offset+d.Y)
        end
    end)
    
    -- Mobile shortcuts bar
    local msb = UI.Create("Frame", {
        Size=UDim2.new(1,0,0,36),
        Position=UDim2.new(0,0,0,0),
        BackgroundColor3=Color3.fromRGB(12,14,22),
        BackgroundTransparency=0.3,
        Visible=false, ZIndex=90, Parent=SG
    })
    UI.Create("UIListLayout", {
        FillDirection=Enum.FillDirection.Horizontal,
        HorizontalAlignment=
            Enum.HorizontalAlignment.Center,
        VerticalAlignment=
            Enum.VerticalAlignment.Center,
        Padding=UDim.new(0,3), Parent=msb
    })
    
    local msDefs = {
        {"⏮",function() Eng:GoTo(0) end},
        {"⏪",function()
            Eng.CurrentTime=math.max(0,
                Eng.CurrentTime-1/Eng.FPS)
            Eng:GoTo(Eng.CurrentTime) end},
        {"▶⏸",function()
            if Eng.IsPlaying then Eng:Pause()
            else Eng:Play() end end},
        {"⏩",function()
            Eng.CurrentTime=
                Eng.CurrentTime+1/Eng.FPS
            Eng:GoTo(Eng.CurrentTime) end},
        {"⏭",function()
            Eng:GoTo(Eng:GetMaxTime()) end},
        {"+KF",function()
            Eng:AddKeyframe() end},
        {"↩️",function() Eng:Undo() end},
        {"↪️",function() Eng:Redo() end},
    }
    for _, d in ipairs(msDefs) do
        local mb = UI.Create("TextButton", {
            Size=UDim2.new(0,38,0,30),
            BackgroundColor3=T.SF,
            Text=d[1], TextColor3=T.TX,
            TextSize=12,
            Font=Enum.Font.GothamBold,
            ZIndex=91, Parent=msb
        })
        UI.Corner(mb, 6)
        mb.MouseButton1Click:Connect(d[2])
    end
    
    spawn(function()
        while SG and SG.Parent do
            msb.Visible = AF and AF.Visible or false
            wait(0.3)
        end
    end)
    
    print("📱 Mobile adaptation applied")
end

