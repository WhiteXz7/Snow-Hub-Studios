    if inp.UserInputType ==
       Enum.UserInputType.MouseButton1 or
       inp.UserInputType ==
       Enum.UserInputType.Touch then
        hd = true
        hds = inp.Position
        hsp = Hub.Position
        inp.Changed:Connect(function()
            if inp.UserInputState ==
               Enum.UserInputState.End then
                hd = false
            end
        end)
    end
end)
Hub.InputChanged:Connect(function(inp)
    if inp.UserInputType ==
       Enum.UserInputType.MouseMovement or
       inp.UserInputType ==
       Enum.UserInputType.Touch then
        hdi = inp
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if inp == hdi and hd then
        local d = inp.Position - hds
        Hub.Position = UDim2.new(
            hsp.X.Scale, hsp.X.Offset+d.X,
            hsp.Y.Scale, hsp.Y.Offset+d.Y)
    end
end)

