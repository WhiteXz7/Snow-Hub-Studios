-- ============================================
local selBtn = TB("🎯Select", 1, T.PU, nil)

local selectMode = false
local selectConn = nil

local function CleanSelect()
    selectMode = false
    if selectConn then
        pcall(function()
            selectConn:Disconnect()
        end)
        selectConn = nil
    end
end

local function FindTarget(obj)
    if not obj then return nil end
    local current = obj
    for i = 1, 5 do
        if not current then break end
        if current:IsA("Model") then
            return current
        end
        current = current.Parent
    end
    if obj:IsA("BasePart") then
        if obj.Parent and obj.Parent:IsA("Model") then
            return obj.Parent
        end
        return obj
    end
    if obj:IsA("GuiObject") then return obj end
    return obj
end

local function SetTarget(tgt)
    if not tgt then return end
    CleanSelect()
    local name = "?"
    pcall(function() name = tgt.Name end)
    local short = name
    if #short > 7 then
        short = short:sub(1, 7)
    end
    Eng:ScanTarget(tgt)
    selBtn.Text = "🎯" .. short
    selBtn.BackgroundColor3 = T.OK
    spawn(function()
        wait(1.5)
        if selBtn and selBtn.Parent then
            selBtn.BackgroundColor3 = T.PU
        end
    end)
end

selBtn.MouseButton1Click:Connect(function()
    if selectMode then
        CleanSelect()
        selBtn.Text = "🎯Select"
        selBtn.BackgroundColor3 = T.PU
        return
    end
    
    selectMode = true
    selBtn.Text = "🎯Click..."
    selBtn.BackgroundColor3 = T.WN
    
    -- Click no mundo 3D
    selectConn = Mouse.Button1Down:Connect(function()
        local hit = nil
        pcall(function()
            hit = Mouse.Target
        end)
        if hit then
            local tgt = FindTarget(hit)
            if tgt then
                SetTarget(tgt)
                return
            end
        end
        CleanSelect()
        selBtn.Text = "🎯Select"
        selBtn.BackgroundColor3 = T.PU
    end)
    
    -- Checagem do Explorer
    spawn(function()
        local checks = 0
        while selectMode and checks < 200 do
            checks = checks + 1
            local ok, result = pcall(function()
                local sel = Selection:Get()
                if sel and type(sel) == "table" and #sel > 0 then
                    local item = sel[1]
                    if item and typeof(item) == "Instance" then
                        return item
                    end
                end
                return nil
            end)
            if ok and result then
                local tgt = FindTarget(result)
                if tgt then
                    SetTarget(tgt)
                    return
                end
            end
            wait(0.15)
        end
        if selectMode then
            CleanSelect()
            pcall(function()
                selBtn.Text = "🎯Select"
                selBtn.BackgroundColor3 = T.PU
            end)
        end
    end)
end)

