function EC:Serialize()
    local data = {KF={}, Spd=self.Speed, AT=self.AnimType, IM=self.InterpMode, Loop=self.IsLooping, FPS=self.FPS, VM=self.ViewMode}
    for i,kf in ipairs(self.Keyframes) do
        local kd = {t=kf.time, j={}}
        for jn,jd in pairs(kf.joints) do
            local d = {ES=jd.ES, ED=jd.ED}
            if jd.CF then pcall(function() d.CF={jd.CF:GetComponents()} end) end
            if jd.SZ and typeof(jd.SZ)=="Vector3" then pcall(function() d.SZ={jd.SZ.X,jd.SZ.Y,jd.SZ.Z} d.ST="V3" end) end
            if jd.Sz then pcall(function() d.Sz={jd.Sz.X.Scale,jd.Sz.X.Offset,jd.Sz.Y.Scale,jd.Sz.Y.Offset} end) end
            if jd.Pos then pcall(function() d.Pos={jd.Pos.X.Scale,jd.Pos.X.Offset,jd.Pos.Y.Scale,jd.Pos.Y.Offset} end) end
            if jd.TR then d.TR=jd.TR end
            if jd.Rot then d.Rot=jd.Rot end
            if jd.Tr then d.Tr=jd.Tr end
            if jd.CL then pcall(function() d.CL={jd.CL.R,jd.CL.G,jd.CL.B} end) end
            if jd.Rate then d.Rate=jd.Rate end
            if jd.Bright then d.Bright=jd.Bright end
            if jd.Range then d.Range=jd.Range end
            kd.j[jn] = d
        end
        data.KF[i] = kd
    end
    return data
end

function EC:Deserialize(data)
    if not data then return end
    self.Speed=data.Spd or 1 self.AnimType=data.AT or "Core" self.InterpMode=data.IM or "Linear"
    self.IsLooping=data.Loop or false self.FPS=data.FPS or 60 self.ViewMode=data.VM or "Global"
    self.Keyframes = {}
    if not data.KF then return end
    for i,kd in ipairs(data.KF) do
        local kf = {time=kd.t, joints={}}
        if kd.j then
            for jn,d in pairs(kd.j) do
                local jd = {ES=d.ES or "Linear", ED=d.ED or "InOut"}
                if d.CF then pcall(function() jd.CF=CFrame.new(unpack(d.CF)) end) end
                if d.SZ and d.ST=="V3" then pcall(function() jd.SZ=Vector3.new(unpack(d.SZ)) end) end
                if d.Sz then pcall(function() jd.Sz=UDim2.new(unpack(d.Sz)) end) end
                if d.Pos then pcall(function() jd.Pos=UDim2.new(unpack(d.Pos)) end) end
                if d.TR then jd.TR=d.TR end if d.Rot then jd.Rot=d.Rot end if d.Tr then jd.Tr=d.Tr end
                if d.CL then pcall(function() jd.CL=Color3.new(unpack(d.CL)) end) end
                if d.Rate then jd.Rate=d.Rate end if d.Bright then jd.Bright=d.Bright end if d.Range then jd.Range=d.Range end
                kf.joints[jn] = jd
            end
        end
        self.Keyframes[i] = kf
    end
end

function EC:GenExportScript()
    local s = "-- Snow Animator Pro Export\nlocal RS=game:GetService('RunService')\nlocal D={Spd="..self.Speed..",Loop="..tostring(self.IsLooping)..",KF={\n"
    for _,kf in ipairs(self.Keyframes) do
        s=s.."{t="..kf.time..",j={\n"
        for jn,d in pairs(kf.joints) do
            s=s..'["'..jn..'"]={'
            if d.CF then pcall(function() local c={d.CF:GetComponents()} s=s.."CF=CFrame.new("..table.concat(c,",")..")," end) end
            if d.TR then s=s.."TR="..d.TR.."," end
            s=s..'ES="'..(d.ES or "Linear")..'",ED="'..(d.ED or "InOut")..'"'
            s=s.."},\n"
        end
        s=s.."}},\n"
    end
    s=s.."}}\nlocal tgt=script.Parent\nlocal js={}\nfor _,d in ipairs(tgt:GetDescendants()) do if d:IsA('Motor6D') then js[d.Name]=d end end\n"
    s=s.."local st=tick() local mx=0\nfor _,k in ipairs(D.KF) do if k.t>mx then mx=k.t end end\n"
    s=s.."local cn cn=RS.Heartbeat:Connect(function()\nlocal el=(tick()-st)*D.Spd\nif el>mx then if D.Loop then st=tick() el=0 else cn:Disconnect() return end end\n"
    s=s.."local pv,nx for _,k in ipairs(D.KF) do if k.t<=el then pv=k end if k.t>=el and not nx then nx=k end end\n"
    s=s.."if not pv then pv=D.KF[1] end if not nx then nx=D.KF[#D.KF] end\n"
    s=s.."if pv and nx and pv~=nx then local a=math.clamp((el-pv.t)/(nx.t-pv.t),0,1)\n"
    s=s.."for jn,pd in pairs(pv.j) do local nd=nx.j[jn] if nd and js[jn] then if pd.CF and nd.CF then js[jn].C0=pd.CF:Lerp(nd.CF,a) end end end end end)\n"
    return s
end

function EC:ExportToRS(expType)
    self.ExportCount = self.ExportCount + 1
    local fn = "SNA_"..string.format("%03d", self.ExportCount)
    pcall(function()
        local mf = Instance.new("Folder") mf.Name=fn mf.Parent=ReplicatedStorage
        local at=Instance.new("StringValue") at.Name="AnimType" at.Value=self.AnimType at.Parent=mf
        local sv=Instance.new("NumberValue") sv.Name="Speed" sv.Value=self.Speed sv.Parent=mf
        local lv=Instance.new("BoolValue") lv.Name="Loop" lv.Value=self.IsLooping lv.Parent=mf
        local et=Instance.new("StringValue") et.Name="ExportType" et.Value=expType or "NPC" et.Parent=mf
        local kff=Instance.new("Folder") kff.Name="KeyFrames" kff.Parent=mf
        for i,kf in ipairs(self.Keyframes) do
            local ki=Instance.new("Folder") ki.Name="KF_"..string.format("%04d",i) ki.Parent=kff
            local tv=Instance.new("NumberValue") tv.Name="Time" tv.Value=kf.time tv.Parent=ki
            local jf=Instance.new("Folder") jf.Name="Joints" jf.Parent=ki
            for jn,d in pairs(kf.joints) do
                local jfi=Instance.new("Folder") jfi.Name=jn jfi.Parent=jf
                if d.CF then pcall(function() local cv=Instance.new("CFrameValue") cv.Name="CF" cv.Value=d.CF cv.Parent=jfi end) end
            end
        end
        local ps=Instance.new("ModuleScript") ps.Name="Playback" ps.Source=self:GenExportScript() ps.Parent=mf
    end)
    return fn
end

