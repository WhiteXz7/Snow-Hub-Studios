EC = {}
EC.__index = EC
function EC.new()
    local s = setmetatable({}, EC)
    s.Keyframes = {}
    s.CurrentTime = 0
    s.FPS = 60
    s.IsPlaying = false
    s.IsLooping = false
    s.Speed = 1
    s.Target = nil
    s.AllJoints = {}
    s.AnimType = "Core"
    s.InterpMode = "Linear"
    s.ViewMode = "Global"
    s.UndoStack = {}
    s.RedoStack = {}
    s.Clipboard = nil
    s.ExportCount = 0
    s.AutoKey = false
    s.OnionSkin = false
    s.MirrorAxis = "X"
    s.SnapGrid = false
    s.GridSize = 0.5
    s.Markers = {}
    s.EasingDir = "InOut"
    s.PlayConn = nil
    s.AnimTypes = {"Core","Idle","Walk","Run","Jump","Climb","Fall","FreeFall","Swim","SwimIdle","Seated","Action1","Action2","Action3","Action4","Emote","Dance","Dance2","Dance3","Laugh","Cheer","Wave","Point","Custom1","Custom2","Custom3"}
    s.InterpModes = {"Linear","Cubic","Bounce","Elastic","Back","Quad","Quart","Quint","Sine","Expo","Circ","Constant"}
    s.EasingDirs = {"In","Out","InOut"}
    return s
end
function EC:PushUndo()
    table.insert(self.UndoStack, {KF=self:CopyKFs(), Time=self.CurrentTime, Spd=self.Speed})
    if #self.UndoStack > 80 then table.remove(self.UndoStack, 1) end
    self.RedoStack = {}
end
function EC:Undo()
    if #self.UndoStack == 0 then return end
    table.insert(self.RedoStack, {KF=self:CopyKFs(), Time=self.CurrentTime, Spd=self.Speed})
    local s = table.remove(self.UndoStack)
    self.Keyframes = s.KF
    self.CurrentTime = s.Time
    self.Speed = s.Spd
end
function EC:Redo()
    if #self.RedoStack == 0 then return end
    table.insert(self.UndoStack, {KF=self:CopyKFs(), Time=self.CurrentTime, Spd=self.Speed})
    local s = table.remove(self.RedoStack)
    self.Keyframes = s.KF
    self.CurrentTime = s.Time
    self.Speed = s.Spd
end
function EC:CopyKFs()
    local c = {}
    for i, kf in ipairs(self.Keyframes) do
        local cp = {time=kf.time, joints={}}
        for n, d in pairs(kf.joints) do
            local dd = {}
            for k, v in pairs(d) do dd[k] = v end
            cp.joints[n] = dd
        end
        c[i] = cp
    end
    return c
end
function EC:JValid(j)
    if not j or not j.Inst then return false end
    local ok, r = pcall(function() return j.Inst.Parent ~= nil end)
    return ok and r
end
function EC:ScanTarget(target)
    self.AllJoints = {}
    self.Target = target
    if not target then return end
    local mp = {}
    pcall(function()
        for _, ch in ipairs(target:GetDescendants()) do
            pcall(function()
                if ch:IsA("Motor6D") then
                    table.insert(self.AllJoints, {Type="Motor6D", Inst=ch, Name=ch.Name, OC0=ch.C0, OC1=ch.C1})
                    if ch.Part1 then mp[ch.Part1] = true end
                end
            end)
        end
    end)
    pcall(function()
        for _, ch in ipairs(target:GetDescendants()) do
            pcall(function()
                if ch:IsA("BasePart") and not ch:IsA("Terrain") and not mp[ch] then
                    table.insert(self.AllJoints, {Type="Part", Inst=ch, Name=ch.Name.."_P", OCF=ch.CFrame})
                end
            end)
        end
    end)
    pcall(function()
        if target:IsA("BasePart") and not target:IsA("Terrain") then
            local found = false
            for _, j in ipairs(self.AllJoints) do if j.Inst == target then found = true end end
            if not found then
                table.insert(self.AllJoints, {Type="Part", Inst=target, Name=target.Name.."_P", OCF=target.CFrame})
            end
        end
    end)
    pcall(function()
        for _, ch in ipairs(target:GetDescendants()) do
            pcall(function()
                if ch:IsA("GuiObject") then
                    table.insert(self.AllJoints, {Type="GUI", Inst=ch, Name=ch.Name.."_G", OPos=ch.Position, OSize=ch.Size, ORot=ch.Rotation})
                end
            end)
        end
    end)
    pcall(function()
        for _, ch in ipairs(target:GetDescendants()) do
            pcall(function()
                if ch:IsA("ParticleEmitter") or ch:IsA("PointLight") or ch:IsA("SpotLight") or ch:IsA("Fire") or ch:IsA("Smoke") then
                    table.insert(self.AllJoints, {Type="FX", Inst=ch, Name=ch.Name.."_FX"})
                end
            end)
        end
    end)
end
function EC:AddKeyframe()
    self:PushUndo()
    local kf = {time=self.CurrentTime, joints={}}
    for _, j in ipairs(self.AllJoints) do
        if self:JValid(j) then
            pcall(function()
                if j.Type == "Motor6D" then
                    kf.joints[j.Name] = {CF=j.Inst.C0, ES=self.InterpMode, ED=self.EasingDir}
                elseif j.Type == "Part" then
                    kf.joints[j.Name] = {CF=j.Inst.CFrame, SZ=j.Inst.Size, TR=j.Inst.Transparency, CL=j.Inst.Color, ES=self.InterpMode, ED=self.EasingDir}
                elseif j.Type == "GUI" then
                    kf.joints[j.Name] = {Pos=j.Inst.Position, Sz=j.Inst.Size, Rot=j.Inst.Rotation, Tr=j.Inst.BackgroundTransparency, ES=self.InterpMode, ED=self.EasingDir}
                elseif j.Type == "FX" then
                    local d = {ES=self.InterpMode, ED=self.EasingDir}
                    pcall(function() if j.Inst:IsA("ParticleEmitter") then d.Rate = j.Inst.Rate end end)
                    pcall(function() if j.Inst:IsA("PointLight") or j.Inst:IsA("SpotLight") then d.Bright=j.Inst.Brightness d.Range=j.Inst.Range end end)
                    kf.joints[j.Name] = d
                end
            end)
        end
    end
    local nl = {}
    for _, ek in ipairs(self.Keyframes) do
        if math.abs(ek.time - self.CurrentTime) >= 0.001 then table.insert(nl, ek) end
    end
    self.Keyframes = nl
    table.insert(self.Keyframes, kf)
    table.sort(self.Keyframes, function(a,b) return a.time < b.time end)
end
function EC:RemoveKFAt(time)
    self:PushUndo()
    local nl = {}
    for _, kf in ipairs(self.Keyframes) do
        if math.abs(kf.time - time) >= 0.05 then table.insert(nl, kf) end
    end
    self.Keyframes = nl
end
function EC:GetMaxTime()
    local mx = 0
    for _, kf in ipairs(self.Keyframes) do if kf.time > mx then mx = kf.time end end
    return math.max(mx, 0.1)
end
function EC.BounceOut(t)
    if t < 1/2.75 then return 7.5625*t*t
    elseif t < 2/2.75 then t=t-1.5/2.75 return 7.5625*t*t+0.75
    elseif t < 2.5/2.75 then t=t-2.25/2.75 return 7.5625*t*t+0.9375
    else t=t-2.625/2.75 return 7.5625*t*t+0.984375 end
end
function EC:ApplyEasing(a, style, dir)
    if not style or style == "Linear" then return a end
    if style == "Constant" then return a >= 1 and 1 or 0 end
    local function eIn(t, s)
        if s=="Quad" then return t*t end
        if s=="Cubic" then return t*t*t end
        if s=="Quart" then return t^4 end
        if s=="Quint" then return t^5 end
        if s=="Sine" then return 1-math.cos(t*math.pi/2) end
        if s=="Expo" then return t==0 and 0 or math.pow(2,10*(t-1)) end
        if s=="Circ" then return 1-math.sqrt(math.abs(1-t*t)) end
        if s=="Back" then local c=1.70158 return t*t*((c+1)*t-c) end
        if s=="Elastic" then if t==0 or t==1 then return t end return -math.pow(2,10*(t-1))*math.sin((t-1.1)*5*math.pi) end
        if s=="Bounce" then return 1-EC.BounceOut(1-t) end
        return t
    end
    local function eOut(t, s)
        if s=="Bounce" then return EC.BounceOut(t) end
        return 1-eIn(1-t, s)
    end
    dir = dir or "InOut"
    if dir=="In" then return eIn(a, style)
    elseif dir=="Out" then return eOut(a, style)
    else
        if a < 0.5 then return eIn(a*2, style)/2
        else return 0.5+eOut((a-0.5)*2, style)/2 end
    end
end
function EC:LerpUD2(a,b,t)
    local ok,r = pcall(function() return UDim2.new(a.X.Scale+(b.X.Scale-a.X.Scale)*t, a.X.Offset+(b.X.Offset-a.X.Offset)*t, a.Y.Scale+(b.Y.Scale-a.Y.Scale)*t, a.Y.Offset+(b.Y.Offset-a.Y.Offset)*t) end)
    return ok and r or a
end
function EC:LerpC3(a,b,t)
    local ok,r = pcall(function() return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t) end)
    return ok and r or a
end
function EC:LerpNum(a,b,t) if a==nil or b==nil then return a end return a+(b-a)*t end
function EC:LerpCF(a,b,t) local ok,r = pcall(function() return a:Lerp(b,t) end) return ok and r or a end
function EC:LerpV3(a,b,t) local ok,r = pcall(function() return a:Lerp(b,t) end) return ok and r or a end

function EC:Evaluate(time)
    if #self.Keyframes == 0 then return nil end
    if #self.Keyframes == 1 then return self.Keyframes[1] end
    local prev, nxt = nil, nil
    for i = 1, #self.Keyframes do
        local kf = self.Keyframes[i]
        if kf.time <= time then prev = kf end
        if kf.time >= time and nxt == nil then nxt = kf end
    end
    if not prev then prev = self.Keyframes[1] end
    if not nxt then nxt = self.Keyframes[#self.Keyframes] end
    if prev == nxt then return prev end
    local diff = nxt.time - prev.time
    if diff <= 0 then return prev end
    local raw = math.clamp((time - prev.time)/diff, 0, 1)
    local result = {time=time, joints={}}
    local allN = {}
    for jn,_ in pairs(prev.joints) do allN[jn] = true end
    for jn,_ in pairs(nxt.joints) do allN[jn] = true end
    for jn,_ in pairs(allN) do
        local pd = prev.joints[jn]
        local nd = nxt.joints[jn]
        if pd and not nd then result.joints[jn] = pd
        elseif nd and not pd then result.joints[jn] = nd
        elseif pd and nd then
            local es = nd.ES or "Linear"
            local ed = nd.ED or "InOut"
            local ea = self:ApplyEasing(raw, es, ed)
            local ip = {ES=es, ED=ed}
            if pd.CF and nd.CF then ip.CF = self:LerpCF(pd.CF, nd.CF, ea) elseif pd.CF then ip.CF=pd.CF elseif nd.CF then ip.CF=nd.CF end
            if pd.SZ and nd.SZ then
                if typeof(pd.SZ)=="Vector3" and typeof(nd.SZ)=="Vector3" then ip.SZ=self:LerpV3(pd.SZ,nd.SZ,ea)
                elseif typeof(pd.SZ)=="UDim2" and typeof(nd.SZ)=="UDim2" then ip.SZ=self:LerpUD2(pd.SZ,nd.SZ,ea)
                else ip.SZ=nd.SZ end
            elseif pd.SZ then ip.SZ=pd.SZ elseif nd.SZ then ip.SZ=nd.SZ end
            if pd.TR~=nil and nd.TR~=nil then ip.TR=self:LerpNum(pd.TR,nd.TR,ea) elseif pd.TR~=nil then ip.TR=pd.TR elseif nd.TR~=nil then ip.TR=nd.TR end
            if pd.CL and nd.CL then ip.CL=self:LerpC3(pd.CL,nd.CL,ea) elseif pd.CL then ip.CL=pd.CL elseif nd.CL then ip.CL=nd.CL end
            if pd.Pos and nd.Pos then ip.Pos=self:LerpUD2(pd.Pos,nd.Pos,ea) elseif pd.Pos then ip.Pos=pd.Pos elseif nd.Pos then ip.Pos=nd.Pos end
            if pd.Sz and nd.Sz then ip.Sz=self:LerpUD2(pd.Sz,nd.Sz,ea) elseif pd.Sz then ip.Sz=pd.Sz elseif nd.Sz then ip.Sz=nd.Sz end
            if pd.Rot~=nil and nd.Rot~=nil then ip.Rot=self:LerpNum(pd.Rot,nd.Rot,ea) elseif pd.Rot~=nil then ip.Rot=pd.Rot elseif nd.Rot~=nil then ip.Rot=nd.Rot end
            if pd.Tr~=nil and nd.Tr~=nil then ip.Tr=self:LerpNum(pd.Tr,nd.Tr,ea) elseif pd.Tr~=nil then ip.Tr=pd.Tr elseif nd.Tr~=nil then ip.Tr=nd.Tr end
            if pd.Rate~=nil and nd.Rate~=nil then ip.Rate=self:LerpNum(pd.Rate,nd.Rate,ea) elseif pd.Rate~=nil then ip.Rate=pd.Rate end
            if pd.Bright~=nil and nd.Bright~=nil then ip.Bright=self:LerpNum(pd.Bright,nd.Bright,ea) elseif pd.Bright~=nil then ip.Bright=pd.Bright end
            if pd.Range~=nil and nd.Range~=nil then ip.Range=self:LerpNum(pd.Range,nd.Range,ea) elseif pd.Range~=nil then ip.Range=pd.Range end
            result.joints[jn] = ip
        end
    end
    return result
end

function EC:ApplyFrame(fd)
    if not fd or not fd.joints then return end
    for i = 1, #self.AllJoints do
        local j = self.AllJoints[i]
        if j and self:JValid(j) then
            local d = fd.joints[j.Name]
            if d then
                pcall(function()
                    if j.Type=="Motor6D" then if d.CF then j.Inst.C0=d.CF end
                    elseif j.Type=="Part" then
                        if d.CF then j.Inst.CFrame=d.CF end
                        if d.SZ and typeof(d.SZ)=="Vector3" then j.Inst.Size=d.SZ end
                        if d.TR~=nil then j.Inst.Transparency=d.TR end
                        if d.CL then j.Inst.Color=d.CL end
                    elseif j.Type=="GUI" then
                        if d.Pos then j.Inst.Position=d.Pos end
                        if d.Sz then j.Inst.Size=d.Sz end
                        if d.Rot~=nil then j.Inst.Rotation=d.Rot end
                        if d.Tr~=nil then j.Inst.BackgroundTransparency=d.Tr end
                    elseif j.Type=="FX" then
                        pcall(function() if d.Rate~=nil then j.Inst.Rate=d.Rate end end)
                        pcall(function() if d.Bright~=nil then j.Inst.Brightness=d.Bright end end)
                        pcall(function() if d.Range~=nil then j.Inst.Range=d.Range end end)
                    end
                end)
            end
        end
    end
end

function EC:GoTo(time)
    self.CurrentTime = math.max(0, time)
    local fd = self:Evaluate(self.CurrentTime)
    if fd then self:ApplyFrame(fd) end
end
function EC:Play()
    if self.IsPlaying then return end
    if #self.Keyframes < 2 then return end
    self.IsPlaying = true
    local st = tick()
    local sa = self.CurrentTime
    local mx = self:GetMaxTime()
    if self.PlayConn then pcall(function() self.PlayConn:Disconnect() end) self.PlayConn = nil end
    self.PlayConn = RunService.RenderStepped:Connect(function()
        if not self.IsPlaying then
            pcall(function() if self.PlayConn then self.PlayConn:Disconnect() self.PlayConn=nil end end)
            return
        end
        local el = (tick()-st)*self.Speed
        self.CurrentTime = sa + el
        if self.CurrentTime >= mx then
            if self.IsLooping then st=tick() sa=0 self.CurrentTime=0
            else self.CurrentTime=mx self.IsPlaying=false
                pcall(function() if self.PlayConn then self.PlayConn:Disconnect() self.PlayConn=nil end end) return
            end
        end
        local fd = self:Evaluate(self.CurrentTime)
        if fd then self:ApplyFrame(fd) end
    end)
end
function EC:Stop()
    self.IsPlaying = false
    if self.PlayConn then pcall(function() self.PlayConn:Disconnect() end) self.PlayConn = nil end
end
function EC:Pause() self.IsPlaying = false end
function EC:CopyKF()
    for _, kf in ipairs(self.Keyframes) do
        if math.abs(kf.time-self.CurrentTime)<0.05 then
            self.Clipboard = {joints={}}
            for n,d in pairs(kf.joints) do local dd={} for k,v in pairs(d) do dd[k]=v end self.Clipboard.joints[n]=dd end
            return true
        end
    end
    return false
end
function EC:PasteKF()
    if not self.Clipboard then return end
    self:PushUndo()
    local kf = {time=self.CurrentTime, joints={}}
    for n,d in pairs(self.Clipboard.joints) do local dd={} for k,v in pairs(d) do dd[k]=v end kf.joints[n]=dd end
    local nl = {}
    for _,ek in ipairs(self.Keyframes) do if math.abs(ek.time-self.CurrentTime)>=0.001 then table.insert(nl,ek) end end
    self.Keyframes = nl
    table.insert(self.Keyframes, kf)
    table.sort(self.Keyframes, function(a,b) return a.time<b.time end)
end
function EC:ClearAll() self:PushUndo() self.Keyframes = {} end
function EC:MirrorKF()
    self:PushUndo()
    for _, kf in ipairs(self.Keyframes) do
        if math.abs(kf.time-self.CurrentTime)<0.05 then
            for _, d in pairs(kf.joints) do
                if d.CF then pcall(function()
                    local p=d.CF.Position local rx,ry,rz=d.CF:ToEulerAnglesXYZ()
                    if self.MirrorAxis=="X" then d.CF=CFrame.new(-p.X,p.Y,p.Z)*CFrame.Angles(-rx,ry,rz)
                    elseif self.MirrorAxis=="Y" then d.CF=CFrame.new(p.X,-p.Y,p.Z)*CFrame.Angles(rx,-ry,rz)
                    else d.CF=CFrame.new(p.X,p.Y,-p.Z)*CFrame.Angles(rx,ry,-rz) end
                end) end
            end
            break
        end
    end
end
function EC:ReverseKFs()
    self:PushUndo()
    if #self.Keyframes==0 then return end
    local mx=self:GetMaxTime()
    for _,kf in ipairs(self.Keyframes) do kf.time=mx-kf.time end
    table.sort(self.Keyframes, function(a,b) return a.time<b.time end)
end
function EC:DupKF(src,dst)
    self:PushUndo()
    for _,kf in ipairs(self.Keyframes) do
        if math.abs(kf.time-src)<0.05 then
            local nk={time=dst,joints={}}
            for n,d in pairs(kf.joints) do local dd={} for k,v in pairs(d) do dd[k]=v end nk.joints[n]=dd end
            table.insert(self.Keyframes,nk)
            table.sort(self.Keyframes,function(a,b) return a.time<b.time end) return
        end
    end
end
function EC:ScaleTime(f) self:PushUndo() for _,kf in ipairs(self.Keyframes) do kf.time=kf.time*f end end
