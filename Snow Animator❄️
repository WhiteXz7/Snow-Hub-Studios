function Engine:GenExportScript()
    local s = "-- Snow Animator Pro Export\n"
    s=s.."-- Type: "..self.AnimType.."\n"
    s=s.."local RS=game:GetService('RunService')\n"
    s=s.."local D={Spd="..self.Speed
    s=s..",Loop="..tostring(self.IsLooping)
    s=s..",KF={\n"
    
    for _, kf in ipairs(self.Keyframes) do
        s=s.."{t="..kf.time..",j={\n"
        for jn, d in pairs(kf.joints) do
            s=s..'["'..jn..'"]={'
            if d.CF then
                local c={d.CF:GetComponents()}
                s=s.."CF=CFrame.new("
                s=s..table.concat(c,",").."),"
            end
            if d.TR then s=s.."TR="..d.TR.."," end
            s=s..'ES="'..(d.ES or "Linear")..'",'
            s=s..'ED="'..(d.ED or "InOut")..'"'
            s=s.."},\n"
        end
        s=s.."}},\n"
    end
    
    s=s.."}}\n"
    s=s..[[
local tgt=script.Parent
local js={}
for _,d in ipairs(tgt:GetDescendants()) do
    if d:IsA("Motor6D") then js[d.Name]=d end
end
local st=tick()
local mx=0
for _,k in ipairs(D.KF) do
    if k.t>mx then mx=k.t end
end
local cn
cn=RS.Heartbeat:Connect(function()
    local el=(tick()-st)*D.Spd
    if el>mx then
        if D.Loop then st=tick() el=0
        else cn:Disconnect() return end
    end
    local pv,nx
    for _,k in ipairs(D.KF) do
        if k.t<=el then pv=k end
        if k.t>=el and not nx then nx=k end
    end
    if not pv then pv=D.KF[1] end
    if not nx then nx=D.KF[#D.KF] end
    if pv and nx and pv~=nx then
        local a=(el-pv.t)/(nx.t-pv.t)
        a=math.clamp(a,0,1)
        for jn,pd in pairs(pv.j) do
            local nd=nx.j[jn]
            if nd and js[jn] then
                if pd.CF and nd.CF then
                    js[jn].C0=pd.CF:Lerp(nd.CF,a)
                end
            end
        end
    end
end)
]]
    return s
end

-- ============================================
-- EXPORT TO REPLICATED STORAGE
-- ============================================

function Engine:ExportToRS(expType)
    self.ExportCount = self.ExportCount + 1
    local id = string.format("%03d", self.ExportCount)
    local fn = "SNA_"..id
    
    local mf = Instance.new("Folder")
    mf.Name = fn
    mf.Parent = ReplicatedStorage
    
    local at = Instance.new("StringValue")
    at.Name = "AnimType"
    at.Value = self.AnimType
    at.Parent = mf
    
    local sv = Instance.new("NumberValue")
    sv.Name = "Speed"
    sv.Value = self.Speed
    sv.Parent = mf
    
    local lv = Instance.new("BoolValue")
    lv.Name = "Loop"
    lv.Value = self.IsLooping
    lv.Parent = mf
    
    local et = Instance.new("StringValue")
    et.Name = "ExportType"
    et.Value = expType or "NPC"
    et.Parent = mf
    
    local kff = Instance.new("Folder")
    kff.Name = "KeyFrames"
    kff.Parent = mf
    
    for i, kf in ipairs(self.Keyframes) do
        local ki = Instance.new("Folder")
        ki.Name = "KF_"..string.format("%04d",i)
        ki.Parent = kff
        
        local tv = Instance.new("NumberValue")
        tv.Name = "Time"
        tv.Value = kf.time
        tv.Parent = ki
        
        local jf = Instance.new("Folder")
        jf.Name = "Joints"
        jf.Parent = ki
        
        for jn, d in pairs(kf.joints) do
            local jfi = Instance.new("Folder")
            jfi.Name = jn
            jfi.Parent = jf
            if d.CF then
                local cv = Instance.new("CFrameValue")
                cv.Name = "CF"
                cv.Value = d.CF
                cv.Parent = jfi
            end
        end
    end
    
    -- Playback ModuleScript
    local ps = Instance.new("ModuleScript")
    ps.Name = "Playback"
    ps.Source = self:GenExportScript()
    ps.Parent = mf
    
    return fn
end

