function E.bounce(t)
    if t<1/2.75 then return 7.5625*t*t
    elseif t<2/2.75 then t=t-1.5/2.75 return 7.5625*t*t+.75
    elseif t<2.5/2.75 then t=t-2.25/2.75 return 7.5625*t*t+.9375
    else t=t-2.625/2.75 return 7.5625*t*t+.984375 end
end

function E.ease(a, s, d)
    if not s or s=="Linear" then return a end
    if s=="Constant" then return a>=1 and 1 or 0 end
    local function ei(t)
        if s=="Quad" then return t*t end
        if s=="Cubic" then return t*t*t end
        if s=="Quart" then return t^4 end
        if s=="Quint" then return t^5 end
        if s=="Sine" then return 1-math.cos(t*math.pi/2) end
        if s=="Expo" then return t==0 and 0 or 2^(10*(t-1)) end
        if s=="Circ" then return 1-math.sqrt(math.max(0,1-t*t)) end
        if s=="Back" then return t*t*(2.70158*t-1.70158) end
        if s=="Elastic" then
            if t==0 or t==1 then return t end
            return -2^(10*(t-1))*math.sin((t-1.1)*5*math.pi)
        end
        if s=="Bounce" then return 1-E.bounce(1-t) end
        return t
    end
    local function eo(t)
        if s=="Bounce" then return E.bounce(t) end
        return 1-ei(1-t)
    end
    d=d or "InOut"
    if d=="In" then return ei(a)
    elseif d=="Out" then return eo(a)
    else return a<.5 and ei(a*2)/2 or .5+eo((a-.5)*2)/2 end
end

function E.lerpCF(a,b,t) local ok,r=pcall(function() return a:Lerp(b,t) end) return ok and r or a end
function E.lerpV3(a,b,t) local ok,r=pcall(function() return a:Lerp(b,t) end) return ok and r or a end
function E.lerpN(a,b,t) return a+(b-a)*t end
function E.lerpC3(a,b,t) return Color3.new(a.R+(b.R-a.R)*t,a.G+(b.G-a.G)*t,a.B+(b.B-a.B)*t) end
function E.lerpU2(a,b,t) return UDim2.new(a.X.Scale+(b.X.Scale-a.X.Scale)*t,a.X.Offset+(b.X.Offset-a.X.Offset)*t,a.Y.Scale+(b.Y.Scale-a.Y.Scale)*t,a.Y.Offset+(b.Y.Offset-a.Y.Offset)*t) end

function E.valid(j)
    if not j or not j.inst then return false end
    local ok,r=pcall(function() return j.inst.Parent~=nil end)
    return ok and r
end

function E.scan(tgt)
    E.joints = {}
    E.target = tgt
    if not tgt then return end
    local mp = {}
    pcall(function()
        for _,c in ipairs(tgt:GetDescendants()) do
            pcall(function()
                if c:IsA("Motor6D") then
                    table.insert(E.joints, {t="m6d", inst=c, name=c.Name, o=c.C0})
                    if c.Part1 then mp[c.Part1]=true end
                end
            end)
        end
    end)
    pcall(function()
        for _,c in ipairs(tgt:GetDescendants()) do
            pcall(function()
                if c:IsA("BasePart") and not c:IsA("Terrain") and not mp[c] then
                    table.insert(E.joints, {t="part", inst=c, name=c.Name.."_p", o=c.CFrame})
                end
            end)
        end
    end)
    pcall(function()
        if tgt:IsA("BasePart") then
            local f=false
            for _,j in ipairs(E.joints) do if j.inst==tgt then f=true break end end
            if not f then table.insert(E.joints, {t="part", inst=tgt, name=tgt.Name.."_p", o=tgt.CFrame}) end
        end
    end)
    pcall(function()
        for _,c in ipairs(tgt:GetDescendants()) do
            pcall(function()
                if c:IsA("GuiObject") then
                    table.insert(E.joints, {t="gui", inst=c, name=c.Name.."_g", oP=c.Position, oS=c.Size, oR=c.Rotation})
                end
            end)
        end
    end)
end

function E.snapshot()
    local d = {}
    for _,j in ipairs(E.joints) do
        if E.valid(j) then
            pcall(function()
                if j.t=="m6d" then
                    d[j.name] = {cf=j.inst.C0, es=E.interpMode, ed=E.easingDir}
                elseif j.t=="part" then
                    d[j.name] = {cf=j.inst.CFrame, sz=j.inst.Size, tr=j.inst.Transparency, cl=j.inst.Color, es=E.interpMode, ed=E.easingDir}
                elseif j.t=="gui" then
                    d[j.name] = {pos=j.inst.Position, sz=j.inst.Size, rot=j.inst.Rotation, tr=j.inst.BackgroundTransparency, es=E.interpMode, ed=E.easingDir}
                end
            end)
        end
    end
    return d
end

function E.pushUndo()
    local copy = {}
    for i,kf in ipairs(E.kfs) do
        local jc = {}
        for k,v in pairs(kf.j) do
            local vc = {}
            for kk,vv in pairs(v) do vc[kk]=vv end
            jc[k]=vc
        end
        copy[i] = {t=kf.t, j=jc}
    end
    table.insert(E.undos, {kf=copy, time=E.time, spd=E.speed})
    if #E.undos>60 then table.remove(E.undos,1) end
    E.redos = {}
end

function E.undo()
    if #E.undos==0 then return end
    local cur = {}
    for i,kf in ipairs(E.kfs) do
        local jc={} for k,v in pairs(kf.j) do local vc={} for kk,vv in pairs(v) do vc[kk]=vv end jc[k]=vc end
        cur[i]={t=kf.t,j=jc}
    end
    table.insert(E.redos, {kf=cur, time=E.time, spd=E.speed})
    local s = table.remove(E.undos)
    E.kfs=s.kf E.time=s.time E.speed=s.spd
end

function E.redo()
    if #E.redos==0 then return end
    local cur = {}
    for i,kf in ipairs(E.kfs) do
        local jc={} for k,v in pairs(kf.j) do local vc={} for kk,vv in pairs(v) do vc[kk]=vv end jc[k]=vc end
        cur[i]={t=kf.t,j=jc}
    end
    table.insert(E.undos, {kf=cur, time=E.time, spd=E.speed})
    local s = table.remove(E.redos)
    E.kfs=s.kf E.time=s.time E.speed=s.spd
end

function E.addKF()
    E.pushUndo()
    local data = E.snapshot()
    if not data or not next(data) then return end
    local nl = {}
    for _,kf in ipairs(E.kfs) do
        if math.abs(kf.t-E.time)>=0.001 then table.insert(nl,kf) end
    end
    E.kfs = nl
    table.insert(E.kfs, {t=E.time, j=data})
    table.sort(E.kfs, function(a,b) return a.t<b.t end)
end

function E.removeKF()
    E.pushUndo()
    local nl = {}
    for _,kf in ipairs(E.kfs) do
        if math.abs(kf.t-E.time)>=0.05 then table.insert(nl,kf) end
    end
    E.kfs = nl
end

function E.maxTime()
    local m=0
    for _,kf in ipairs(E.kfs) do if kf.t>m then m=kf.t end end
    return math.max(m, 0.1)
end

function E.eval(time)
    local n = #E.kfs
    if n==0 then return nil end
    if n==1 then return E.kfs[1].j end
    local p,nx = nil,nil
    for i=1,n do
        if E.kfs[i].t<=time then p=E.kfs[i] end
        if E.kfs[i].t>=time and nx==nil then nx=E.kfs[i] end
    end
    if not p then p=E.kfs[1] end
    if not nx then nx=E.kfs[n] end
    if p==nx then return p.j end
    local diff = nx.t-p.t
    if diff<=0 then return p.j end
    local raw = math.clamp((time-p.t)/diff, 0, 1)

    local result = {}
    local all = {}
    for k in pairs(p.j) do all[k]=true end
    for k in pairs(nx.j) do all[k]=true end

    for k in pairs(all) do
        local a,b = p.j[k], nx.j[k]
        if a and not b then result[k]=a
        elseif b and not a then result[k]=b
        elseif a and b then
            local ea = E.ease(raw, b.es or "Linear", b.ed or "InOut")
            local r = {es=b.es, ed=b.ed}
            if a.cf and b.cf then r.cf=E.lerpCF(a.cf,b.cf,ea) end
            if a.sz and b.sz then
                if typeof(a.sz)=="Vector3" then r.sz=E.lerpV3(a.sz,b.sz,ea)
                elseif typeof(a.sz)=="UDim2" then r.sz=E.lerpU2(a.sz,b.sz,ea) end
            end
            if a.tr~=nil and b.tr~=nil then r.tr=E.lerpN(a.tr,b.tr,ea) end
            if a.cl and b.cl then r.cl=E.lerpC3(a.cl,b.cl,ea) end
            if a.pos and b.pos then r.pos=E.lerpU2(a.pos,b.pos,ea) end
            if a.rot~=nil and b.rot~=nil then r.rot=E.lerpN(a.rot,b.rot,ea) end
            result[k]=r
        end
    end
    return result
end

function E.apply(data)
    if not data then return end
    for _,j in ipairs(E.joints) do
        local d = data[j.name]
        if d and E.valid(j) then
            pcall(function()
                if j.t=="m6d" then
                    if d.cf then j.inst.C0=d.cf end
                elseif j.t=="part" then
                    if d.cf then j.inst.CFrame=d.cf end
                    if d.sz and typeof(d.sz)=="Vector3" then j.inst.Size=d.sz end
                    if d.tr~=nil then j.inst.Transparency=d.tr end
                    if d.cl then j.inst.Color=d.cl end
                elseif j.t=="gui" then
                    if d.pos then j.inst.Position=d.pos end
                    if d.sz then j.inst.Size=d.sz end
                    if d.rot~=nil then j.inst.Rotation=d.rot end
                    if d.tr~=nil then j.inst.BackgroundTransparency=d.tr end
                end
            end)
        end
    end
end

function E.goTo(t)
    E.time = math.max(0,t)
    local d = E.eval(E.time)
    if d then E.apply(d) end
end

function E.play()
    if E.playing then return end
    if #E.kfs<2 then return end
    E.playing = true
    local st = tick()
    local sa = E.time
    local mx = E.maxTime()
    if E.conn then pcall(function() E.conn:Disconnect() end) E.conn=nil end
    E.conn = SAP.RS.RenderStepped:Connect(function()
        if not E.playing then
            pcall(function() if E.conn then E.conn:Disconnect() E.conn=nil end end)
            return
        end
        local el = (tick()-st)*E.speed
        E.time = sa+el
        if E.time>=mx then
            if E.looping then st=tick() sa=0 E.time=0
            else E.time=mx E.playing=false
                pcall(function() if E.conn then E.conn:Disconnect() E.conn=nil end end)
                return
            end
        end
        local d = E.eval(E.time)
        if d then E.apply(d) end
    end)
end

function E.stop()
    E.playing=false
    if E.conn then pcall(function() E.conn:Disconnect() end) E.conn=nil end
end

function E.pause() E.playing=false end

function E.copyKF()
    for _,kf in ipairs(E.kfs) do
        if math.abs(kf.t-E.time)<0.05 then
            E.clip = {}
            for k,v in pairs(kf.j) do local vc={} for kk,vv in pairs(v) do vc[kk]=vv end E.clip[k]=vc end
            return true
        end
    end
    return false
end

function E.pasteKF()
    if not E.clip then return end
    E.pushUndo()
    local nl={}
    for _,kf in ipairs(E.kfs) do if math.abs(kf.t-E.time)>=0.001 then table.insert(nl,kf) end end
    E.kfs=nl
    local jc={} for k,v in pairs(E.clip) do local vc={} for kk,vv in pairs(v) do vc[kk]=vv end jc[k]=vc end
    table.insert(E.kfs, {t=E.time, j=jc})
    table.sort(E.kfs, function(a,b) return a.t<b.t end)
end

function E.clearAll() E.pushUndo() E.kfs={} end

function E.mirror()
    E.pushUndo()
    for _,kf in ipairs(E.kfs) do
        if math.abs(kf.t-E.time)<0.05 then
            for _,d in pairs(kf.j) do
                if d.cf then pcall(function()
                    local p=d.cf.Position local rx,ry,rz=d.cf:ToEulerAnglesXYZ()
                    if E.mirrorAxis=="X" then d.cf=CFrame.new(-p.X,p.Y,p.Z)*CFrame.Angles(-rx,ry,rz)
                    elseif E.mirrorAxis=="Y" then d.cf=CFrame.new(p.X,-p.Y,p.Z)*CFrame.Angles(rx,-ry,rz)
                    else d.cf=CFrame.new(p.X,p.Y,-p.Z)*CFrame.Angles(rx,ry,-rz) end
                end) end
            end break
        end
    end
end

function E.reverse()
    E.pushUndo()
    if #E.kfs==0 then return end
    local mx=E.maxTime()
    for _,kf in ipairs(E.kfs) do kf.t=mx-kf.t end
    table.sort(E.kfs, function(a,b) return a.t<b.t end)
end

function E.dupKF()
    for _,kf in ipairs(E.kfs) do
        if math.abs(kf.t-E.time)<0.05 then
            E.pushUndo()
            local jc={} for k,v in pairs(kf.j) do local vc={} for kk,vv in pairs(v) do vc[kk]=vv end jc[k]=vc end
            table.insert(E.kfs, {t=E.time+0.5, j=jc})
            table.sort(E.kfs, function(a,b) return a.t<b.t end) return
        end
    end
end

function E.resetPose()
    for _,j in ipairs(E.joints) do
        if E.valid(j) then pcall(function()
            if j.t=="m6d" then j.inst.C0=j.o
            elseif j.t=="part" then j.inst.CFrame=j.o
            elseif j.t=="gui" then j.inst.Position=j.oP j.inst.Size=j.oS j.inst.Rotation=j.oR end
        end) end
    end
end

-- TWEEN MODE (sem keyframes)
E.tweenMode = false
E.tweenDuration = 1
E.tweenStyle = "Quad"
E.tweenDir = "InOut"
E.tweenLoop = false
E.tweenReverse = false
E.tweenStartSnap = nil
E.tweenEndSnap = nil

function E.tweenCapStart()
    E.tweenStartSnap = E.snapshot()
end

function E.tweenCapEnd()
    E.tweenEndSnap = E.snapshot()
end

function E.tweenPlay()
    if not E.tweenStartSnap or not E.tweenEndSnap then return end
    if E.conn then pcall(function() E.conn:Disconnect() end) E.conn=nil end
    E.playing = true
    local st = tick()
    local styleMap = {
        Linear=Enum.EasingStyle.Linear, Quad=Enum.EasingStyle.Quad,
        Cubic=Enum.EasingStyle.Cubic, Sine=Enum.EasingStyle.Sine,
        Bounce=Enum.EasingStyle.Bounce, Elastic=Enum.EasingStyle.Elastic,
        Back=Enum.EasingStyle.Back, Expo=Enum.EasingStyle.Exponential,
    }
    local dirMap = {In=Enum.EasingDirection.In, Out=Enum.EasingDirection.Out, InOut=Enum.EasingDirection.InOut}
    local dur = E.tweenDuration

    E.conn = SAP.RS.RenderStepped:Connect(function()
        if not E.playing then
            pcall(function() if E.conn then E.conn:Disconnect() E.conn=nil end end)
            return
        end
        local elapsed = tick()-st
        local raw = elapsed/dur
        if E.tweenReverse then
            local cycle = elapsed/(dur*2)
            local phase = (elapsed%(dur*2))/dur
            if phase>1 then raw=2-phase else raw=phase end
        end
        if not E.tweenReverse and raw>=1 then
            if E.tweenLoop then st=tick() raw=0
            else raw=1 E.playing=false
                pcall(function() if E.conn then E.conn:Disconnect() E.conn=nil end end)
            end
        end
        if E.tweenReverse and not E.tweenLoop and elapsed>=dur*2 then
            E.playing=false
            pcall(function() if E.conn then E.conn:Disconnect() E.conn=nil end end)
            raw=0
        end
        if E.tweenReverse and E.tweenLoop and elapsed>=dur*2 then
            st=tick()
        end
        raw = math.clamp(raw,0,1)
        local ea = E.ease(raw, E.tweenStyle, E.tweenDir)

        local result = {}
        local ss,se = E.tweenStartSnap, E.tweenEndSnap
        local all = {}
        for k in pairs(ss) do all[k]=true end
        for k in pairs(se) do all[k]=true end
        for k in pairs(all) do
            local a,b = ss[k],se[k]
            if a and not b then result[k]=a
            elseif b and not a then result[k]=b
            elseif a and b then
                local r = {}
                if a.cf and b.cf then r.cf=E.lerpCF(a.cf,b.cf,ea) end
                if a.sz and b.sz then
                    if typeof(a.sz)=="Vector3" then r.sz=E.lerpV3(a.sz,b.sz,ea)
                    elseif typeof(a.sz)=="UDim2" then r.sz=E.lerpU2(a.sz,b.sz,ea) end
                end
                if a.tr~=nil and b.tr~=nil then r.tr=E.lerpN(a.tr,b.tr,ea) end
                if a.cl and b.cl then r.cl=E.lerpC3(a.cl,b.cl,ea) end
                if a.pos and b.pos then r.pos=E.lerpU2(a.pos,b.pos,ea) end
                if a.rot~=nil and b.rot~=nil then r.rot=E.lerpN(a.rot,b.rot,ea) end
                result[k]=r
            end
        end
        E.apply(result)
    end)
end

function E.genScript()
    local s = "-- Snow Animator Pro Export\nlocal RS=game:GetService('RunService')\nlocal D={s="..E.speed..",l="..tostring(E.looping)..",k={\n"
    for _,kf in ipairs(E.kfs) do
        s=s.."{t="..kf.t..",j={\n"
        for jn,d in pairs(kf.j) do
            s=s..'["'..jn..'"]={'
            if d.cf then pcall(function() local c={d.cf:GetComponents()} s=s.."cf=CFrame.new("..table.concat(c,",")..")," end) end
            s=s.."},\n"
        end
        s=s.."}},\n"
    end
    s=s.."}}\nlocal t=script.Parent\nlocal js={}\nfor _,d in ipairs(t:GetDescendants()) do if d:IsA('Motor6D') then js[d.Name]=d end end\n"
    s=s.."local st,mx=tick(),0\nfor _,k in ipairs(D.k) do if k.t>mx then mx=k.t end end\n"
    s=s.."RS.Heartbeat:Connect(function()\nlocal e=(tick()-st)*D.s\nif e>mx then if D.l then st=tick() else return end end\n"
    s=s.."local p,n\nfor _,k in ipairs(D.k) do if k.t<=e then p=k end if k.t>=e and not n then n=k end end\n"
    s=s.."if p and n and p~=n then local a=math.clamp((e-p.t)/(n.t-p.t),0,1)\n"
    s=s.."for j,pd in pairs(p.j) do local nd=n.j[j] if nd and js[j] and pd.cf and nd.cf then js[j].C0=pd.cf:Lerp(nd.cf,a) end end end end)\n"
    return s
end

function E.exportRS(typ)
    local cnt = #SAP.RepStorage:GetChildren()
    local fn = "SNA_"..string.format("%03d",cnt+1)
    pcall(function()
        local f=Instance.new("Folder") f.Name=fn f.Parent=SAP.RepStorage
        local ms=Instance.new("ModuleScript") ms.Name="Playback" ms.Source=E.genScript() ms.Parent=f
        local kff=Instance.new("Folder") kff.Name="KeyFrames" kff.Parent=f
        for i,kf in ipairs(E.kfs) do
            local ki=Instance.new("Folder") ki.Name="KF"..i ki.Parent=kff
            local tv=Instance.new("NumberValue") tv.Name="Time" tv.Value=kf.t tv.Parent=ki
            for jn,d in pairs(kf.j) do
                if d.cf then pcall(function()
                    local cv=Instance.new("CFrameValue") cv.Name=jn cv.Value=d.cf cv.Parent=ki
                end) end
            end
        end
    end)
    return fn
end

function E.serialize()
    local d = {k={},s=E.speed,l=E.looping,at=E.animType,im=E.interpMode}
    for i,kf in ipairs(E.kfs) do
        local jd={}
        for jn,v in pairs(kf.j) do
            local vv={}
            if v.cf then pcall(function() vv.cf={v.cf:GetComponents()} end) end
            if v.sz and typeof(v.sz)=="Vector3" then vv.sz={v.sz.X,v.sz.Y,v.sz.Z} end
            if v.tr~=nil then vv.tr=v.tr end
            if v.cl then vv.cl={v.cl.R,v.cl.G,v.cl.B} end
            if v.pos then pcall(function() vv.pos={v.pos.X.Scale,v.pos.X.Offset,v.pos.Y.Scale,v.pos.Y.Offset} end) end
            if v.rot then vv.rot=v.rot end
            vv.es=v.es vv.ed=v.ed
            jd[jn]=vv
        end
        d.k[i]={t=kf.t,j=jd}
    end
    return d
end

function E.deserialize(d)
    if not d or not d.k then return end
    E.speed=d.s or 1 E.looping=d.l or false E.animType=d.at or "Action1" E.interpMode=d.im or "Linear"
    E.kfs={}
    for i,kd in ipairs(d.k) do
        local jd={}
        for jn,v in pairs(kd.j) do
            local vv={es=v.es,ed=v.ed}
            if v.cf then pcall(function() vv.cf=CFrame.new(unpack(v.cf)) end) end
            if v.sz then pcall(function() vv.sz=Vector3.new(unpack(v.sz)) end) end
            if v.tr~=nil then vv.tr=v.tr end
            if v.cl then pcall(function() vv.cl=Color3.new(unpack(v.cl)) end) end
            if v.pos then pcall(function() vv.pos=UDim2.new(unpack(v.pos)) end) end
            if v.rot then vv.rot=v.rot end
            jd[jn]=vv
        end
        E.kfs[i]={t=kd.t,j=jd}
    end
end

-- SAVE
E.saves = {}
function E.loadSaves()
    pcall(function()
        local f=SAP.RepStorage:FindFirstChild("SnowAnimSaves")
        if f then
            for i=1,10 do
                local sf=f:FindFirstChild("S"..i)
                if sf then
                    local n=sf:FindFirstChild("N")
                    local d=sf:FindFirstChild("D")
                    if n and d and d.Value~="" then
                        E.saves[i]={name=n.Value, data=SAP.HTTP:JSONDecode(d.Value)}
                    end
                end
            end
        end
    end)
end
function E.saveSlot(i,name)
    pcall(function()
        local f=SAP.RepStorage:FindFirstChild("SnowAnimSaves")
        if not f then f=Instance.new("Folder") f.Name="SnowAnimSaves" f.Parent=SAP.RepStorage end
        local sf=f:FindFirstChild("S"..i)
        if not sf then sf=Instance.new("Folder") sf.Name="S"..i sf.Parent=f end
        local n=sf:FindFirstChild("N") if not n then n=Instance.new("StringValue") n.Name="N" n.Parent=sf end n.Value=name
        local d=sf:FindFirstChild("D") if not d then d=Instance.new("StringValue") d.Name="D" d.Parent=sf end d.Value=SAP.HTTP:JSONEncode(E.serialize())
        E.saves[i]={name=name, data=E.serialize()}
    end)
end
function E.deleteSlot(i)
    pcall(function()
        local f=SAP.RepStorage:FindFirstChild("SnowAnimSaves")
        if f then local sf=f:FindFirstChild("S"..i) if sf then sf:Destroy() end end
        E.saves[i]=nil
    end)
end
function E.loadSlot(i)
    if E.saves[i] and E.saves[i].data then E.deserialize(E.saves[i].data) end
end
