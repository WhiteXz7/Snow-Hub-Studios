    f.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dd=true dds=i.Position ddp=f.Position i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then dd=false end end) end end)
