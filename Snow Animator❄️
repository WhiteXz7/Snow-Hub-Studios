local Engine = {}
Engine.__index = Engine

function Engine.new()
    local self = setmetatable({}, Engine)
    self.Keyframes = {}
    self.CurrentTime = 0
    self.FPS = 60
    self.IsPlaying = false
    self.IsLooping = false
    self.Speed = 1
    self.Target = nil
    self.AllJoints = {}
    self.AnimType = "Core"
    self.InterpMode = "Linear"
    self.ViewMode = "Global"
    self.UndoStack = {}
    self.RedoStack = {}
    self.Clipboard = nil
    self.ExportCount = 0
    self.AutoKey = false
    self.OnionSkin = false
    self.MirrorMode = false
    self.MirrorAxis = "X"
    self.SnapGrid = false
    self.GridSize = 0.5
    self.Markers = {}
    self.EasingDir = "InOut"
    self.PlayConn = nil
    
    self.AnimTypes = {
        "Core","Idle","Walk","Run","Jump",
        "Climb","Fall","FreeFall","Swim",
        "SwimIdle","Seated","Action1",
        "Action2","Action3","Action4",
        "Emote","Dance","Dance2","Dance3",
        "Laugh","Cheer","Wave","Point",
        "Custom1","Custom2","Custom3"
    }
    
    self.InterpModes = {
        "Linear","Cubic","Bounce","Elastic",
        "Back","Quad","Quart","Quint",
        "Sine","Expo","Circ","Constant"
    }
    
    self.EasingDirs = {"In","Out","InOut"}
    
    return self
end

function Engine:PushUndo()
    local st = {
        KF = self:CopyKFs(),
        Time = self.CurrentTime,
        Spd = self.Speed
    }
    table.insert(self.UndoStack, st)
    if #self.UndoStack > 80 then
        table.remove(self.UndoStack, 1)
    end
    self.RedoStack = {}
end

function Engine:Undo()
    if #self.UndoStack == 0 then return end
    table.insert(self.RedoStack, {
        KF = self:CopyKFs(),
        Time = self.CurrentTime,
        Spd = self.Speed
    })
    local s = table.remove(self.UndoStack)
    self.Keyframes = s.KF
    self.CurrentTime = s.Time
    self.Speed = s.Spd
end

function Engine:Redo()
    if #self.RedoStack == 0 then return end
    table.insert(self.UndoStack, {
        KF = self:CopyKFs(),
        Time = self.CurrentTime,
        Spd = self.Speed
    })
    local s = table.remove(self.RedoStack)
    self.Keyframes = s.KF
    self.CurrentTime = s.Time
    self.Speed = s.Spd
end

function Engine:CopyKFs()
    local c = {}
    for i, kf in ipairs(self.Keyframes) do
        local copy = {time = kf.time, joints = {}}
        for n, d in pairs(kf.joints) do
            local dd = {}
            for k, v in pairs(d) do
                dd[k] = v
            end
            copy.joints[n] = dd
        end
        c[i] = copy
    end
    return c
end

function Engine:ScanTarget(target)
    self.AllJoints = {}
    self.Target = target
    if not target then return end
    
    local motorPart1s = {}
    
    -- Motor6D (Rigs R6/R15/Custom)
    pcall(function()
        for _, ch in ipairs(target:GetDescendants()) do
            pcall(function()
                if ch:IsA("Motor6D") then
                    table.insert(self.AllJoints, {
                        Type = "Motor6D",
                        Inst = ch,
                        Name = ch.Name,
                        OC0 = ch.C0,
                        OC1 = ch.C1
                    })
                    if ch.Part1 then
                        motorPart1s[ch.Part1] = true
                    end
                end
            end)
        end
    end)
    
    -- BaseParts (que não são Part1 de Motor6D)
    pcall(function()
        for _, ch in ipairs(target:GetDescendants()) do
            pcall(function()
                if ch:IsA("BasePart") and
                   not ch:IsA("Terrain") and
                   not motorPart1s[ch] then
                    table.insert(self.AllJoints, {
                        Type = "Part",
                        Inst = ch,
                        Name = ch.Name .. "_P",
                        OCF = ch.CFrame
                    })
                end
            end)
        end
    end)
    
    -- Se o target é uma BasePart solta
    pcall(function()
        if target:IsA("BasePart") and
           not target:IsA("Terrain") then
            local found = false
            for _, j in ipairs(self.AllJoints) do
                if j.Inst == target then
                    found = true
                    break
                end
            end
            if not found then
                table.insert(self.AllJoints, {
                    Type = "Part",
                    Inst = target,
                    Name = target.Name .. "_P",
                    OCF = target.CFrame
                })
            end
        end
    end)
    
    -- GuiObjects
    pcall(function()
        for _, ch in ipairs(target:GetDescendants()) do
            pcall(function()
                if ch:IsA("GuiObject") then
                    table.insert(self.AllJoints, {
                        Type = "GUI",
                        Inst = ch,
                        Name = ch.Name .. "_G",
                        OPos = ch.Position,
                        OSize = ch.Size,
                        ORot = ch.Rotation
                    })
                end
            end)
        end
    end)
    
    -- Effects
    pcall(function()
        for _, ch in ipairs(target:GetDescendants()) do
            pcall(function()
                if ch:IsA("ParticleEmitter") or
                   ch:IsA("PointLight") or
                   ch:IsA("SpotLight") or
                   ch:IsA("Fire") or
                   ch:IsA("Smoke") then
                    table.insert(self.AllJoints, {
                        Type = "FX",
                        Inst = ch,
                        Name = ch.Name .. "_FX",
                        CN = ch.ClassName
                    })
                end
            end)
        end
    end)
end

function Engine:IsJointValid(j)
    if not j then return false end
    if not j.Inst then return false end
    local ok, result = pcall(function()
        return j.Inst.Parent ~= nil
    end)
    return ok and result
end

function Engine:AddKeyframe()
    self:PushUndo()
    local kf = {
        time = self.CurrentTime,
        joints = {}
    }
    
    for _, j in ipairs(self.AllJoints) do
        if self:IsJointValid(j) then
            pcall(function()
                if j.Type == "Motor6D" then
                    kf.joints[j.Name] = {
                        CF = j.Inst.C0,
                        ES = self.InterpMode,
                        ED = self.EasingDir
                    }
                elseif j.Type == "Part" then
                    kf.joints[j.Name] = {
                        CF = j.Inst.CFrame,
                        SZ = j.Inst.Size,
                        TR = j.Inst.Transparency,
                        CL = j.Inst.Color,
                        ES = self.InterpMode,
                        ED = self.EasingDir
                    }
                elseif j.Type == "GUI" then
                    kf.joints[j.Name] = {
                        Pos = j.Inst.Position,
                        Sz = j.Inst.Size,
                        Rot = j.Inst.Rotation,
                        Tr = j.Inst.BackgroundTransparency,
                        ES = self.InterpMode,
                        ED = self.EasingDir
                    }
                elseif j.Type == "FX" then
                    local d = {
                        ES = self.InterpMode,
                        ED = self.EasingDir
                    }
                    if j.Inst:IsA("ParticleEmitter") then
                        d.Rate = j.Inst.Rate
                    end
                    if j.Inst:IsA("PointLight") or
                       j.Inst:IsA("SpotLight") then
                        d.Bright = j.Inst.Brightness
                        d.Range = j.Inst.Range
                    end
                    kf.joints[j.Name] = d
                end
            end)
        end
    end
    
    -- Remove keyframe no mesmo tempo
    local newList = {}
    for _, existingKF in ipairs(self.Keyframes) do
        if math.abs(existingKF.time - self.CurrentTime) >= 0.001 then
            table.insert(newList, existingKF)
        end
    end
    self.Keyframes = newList
    
    table.insert(self.Keyframes, kf)
    table.sort(self.Keyframes, function(a, b)
        return a.time < b.time
    end)
end

function Engine:RemoveKFAt(time)
    self:PushUndo()
    local newList = {}
    for _, kf in ipairs(self.Keyframes) do
        if math.abs(kf.time - time) >= 0.05 then
            table.insert(newList, kf)
        end
    end
    self.Keyframes = newList
end

function Engine:GetMaxTime()
    local mx = 0
    for _, kf in ipairs(self.Keyframes) do
        if kf.time > mx then mx = kf.time end
    end
    return math.max(mx, 0.1)
end

function Engine:ApplyEasing(a, style, dir)
    if not style or style == "Linear" then
        return a
    end
    if style == "Constant" then
        if a >= 1 then return 1 end
        return 0
    end
    
    local function eIn(t, s)
        if s == "Quad" then return t * t end
        if s == "Cubic" then return t * t * t end
        if s == "Quart" then return t ^ 4 end
        if s == "Quint" then return t ^ 5 end
        if s == "Sine" then
            return 1 - math.cos(t * math.pi / 2)
        end
        if s == "Expo" then
            if t == 0 then return 0 end
            return math.pow(2, 10 * (t - 1))
        end
        if s == "Circ" then
            return 1 - math.sqrt(1 - t * t)
        end
        if s == "Back" then
            local c = 1.70158
            return t * t * ((c + 1) * t - c)
        end
        if s == "Elastic" then
            if t == 0 or t == 1 then return t end
            return -math.pow(2, 10 * (t - 1)) *
                math.sin((t - 1.1) * 5 * math.pi)
        end
        if s == "Bounce" then
            return 1 - Engine.BounceOut(1 - t)
        end
        return t
    end
    
    local function eOut(t, s)
        if s == "Bounce" then
            return Engine.BounceOut(t)
        end
        return 1 - eIn(1 - t, s)
    end
    
    if not dir then dir = "InOut" end
    
    if dir == "In" then
        return eIn(a, style)
    elseif dir == "Out" then
        return eOut(a, style)
    else
        if a < 0.5 then
            return eIn(a * 2, style) / 2
        else
            return 0.5 + eOut((a - 0.5) * 2, style) / 2
        end
    end
end

function Engine.BounceOut(t)
    if t < 1 / 2.75 then
        return 7.5625 * t * t
    elseif t < 2 / 2.75 then
        t = t - 1.5 / 2.75
        return 7.5625 * t * t + 0.75
    elseif t < 2.5 / 2.75 then
        t = t - 2.25 / 2.75
        return 7.5625 * t * t + 0.9375
    else
        t = t - 2.625 / 2.75
        return 7.5625 * t * t + 0.984375
    end
end

function Engine:LerpUD2(a, b, t)
    local ok, result = pcall(function()
        return UDim2.new(
            a.X.Scale + (b.X.Scale - a.X.Scale) * t,
            a.X.Offset + (b.X.Offset - a.X.Offset) * t,
            a.Y.Scale + (b.Y.Scale - a.Y.Scale) * t,
            a.Y.Offset + (b.Y.Offset - a.Y.Offset) * t
        )
    end)
    if ok then return result end
    return a
end

function Engine:LerpC3(a, b, t)
    local ok, result = pcall(function()
        return Color3.new(
            a.R + (b.R - a.R) * t,
            a.G + (b.G - a.G) * t,
            a.B + (b.B - a.B) * t
        )
    end)
    if ok then return result end
    return a
end

function Engine:LerpNum(a, b, t)
    if a == nil or b == nil then return a end
    return a + (b - a) * t
end

function Engine:LerpCF(a, b, t)
    local ok, result = pcall(function()
        return a:Lerp(b, t)
    end)
    if ok then return result end
    return a
end

function Engine:LerpV3(a, b, t)
    local ok, result = pcall(function()
        return a:Lerp(b, t)
    end)
    if ok then return result end
    return a
end

function Engine:Evaluate(time)
    if #self.Keyframes == 0 then
        return nil
    end
    if #self.Keyframes == 1 then
        return self.Keyframes[1]
    end
    
    -- Achar prev e next keyframe
    local prev = nil
    local nxt = nil
    
    for i = 1, #self.Keyframes do
        local kf = self.Keyframes[i]
        if kf.time <= time then
            prev = kf
        end
        if kf.time >= time and nxt == nil then
            nxt = kf
        end
    end
    
    if prev == nil then
        prev = self.Keyframes[1]
    end
    if nxt == nil then
        nxt = self.Keyframes[#self.Keyframes]
    end
    
    -- Se são o mesmo keyframe
    if prev == nxt then
        return prev
    end
    if prev.time == nxt.time then
        return prev
    end
    
    -- Calcular alpha
    local diff = nxt.time - prev.time
    if diff <= 0 then
        return prev
    end
    
    local rawAlpha = (time - prev.time) / diff
    rawAlpha = math.clamp(rawAlpha, 0, 1)
    
    -- Resultado interpolado
    local result = {time = time, joints = {}}
    
    -- Coletar todos os nomes de joints
    local allNames = {}
    for jn, _ in pairs(prev.joints) do
        allNames[jn] = true
    end
    for jn, _ in pairs(nxt.joints) do
        allNames[jn] = true
    end
    
    for jn, _ in pairs(allNames) do
        local pd = prev.joints[jn]
        local nd = nxt.joints[jn]
        
        -- Se só existe em um dos dois
        if pd and not nd then
            result.joints[jn] = pd
        elseif nd and not pd then
            result.joints[jn] = nd
        elseif pd and nd then
            -- Interpolar
            local easingStyle = nd.ES or "Linear"
            local easingDir = nd.ED or "InOut"
            local ea = self:ApplyEasing(
                rawAlpha, easingStyle, easingDir
            )
            
            local interp = {
                ES = easingStyle,
                ED = easingDir
            }
            
            -- CFrame
            if pd.CF and nd.CF then
                interp.CF = self:LerpCF(pd.CF, nd.CF, ea)
            elseif pd.CF then
                interp.CF = pd.CF
            elseif nd.CF then
                interp.CF = nd.CF
            end
            
            -- Size Vector3
            if pd.SZ and nd.SZ then
                if typeof(pd.SZ) == "Vector3" and
                   typeof(nd.SZ) == "Vector3" then
                    interp.SZ = self:LerpV3(pd.SZ, nd.SZ, ea)
                elseif typeof(pd.SZ) == "UDim2" and
                       typeof(nd.SZ) == "UDim2" then
                    interp.SZ = self:LerpUD2(pd.SZ, nd.SZ, ea)
                else
                    interp.SZ = nd.SZ
                end
            elseif pd.SZ then
                interp.SZ = pd.SZ
            elseif nd.SZ then
                interp.SZ = nd.SZ
            end
            
            -- Transparency
            if pd.TR ~= nil and nd.TR ~= nil then
                interp.TR = self:LerpNum(pd.TR, nd.TR, ea)
            elseif pd.TR ~= nil then
                interp.TR = pd.TR
            elseif nd.TR ~= nil then
                interp.TR = nd.TR
            end
            
            -- Color
            if pd.CL and nd.CL then
                interp.CL = self:LerpC3(pd.CL, nd.CL, ea)
            elseif pd.CL then
                interp.CL = pd.CL
            elseif nd.CL then
                interp.CL = nd.CL
            end
            
            -- GUI Position
            if pd.Pos and nd.Pos then
                interp.Pos = self:LerpUD2(pd.Pos, nd.Pos, ea)
            elseif pd.Pos then
                interp.Pos = pd.Pos
            elseif nd.Pos then
                interp.Pos = nd.Pos
            end
            
            -- GUI Size
            if pd.Sz and nd.Sz then
                interp.Sz = self:LerpUD2(pd.Sz, nd.Sz, ea)
            elseif pd.Sz then
                interp.Sz = pd.Sz
            elseif nd.Sz then
                interp.Sz = nd.Sz
            end
            
            -- Rotation
            if pd.Rot ~= nil and nd.Rot ~= nil then
                interp.Rot = self:LerpNum(pd.Rot, nd.Rot, ea)
            elseif pd.Rot ~= nil then
                interp.Rot = pd.Rot
            elseif nd.Rot ~= nil then
                interp.Rot = nd.Rot
            end
            
            -- GUI Transparency
            if pd.Tr ~= nil and nd.Tr ~= nil then
                interp.Tr = self:LerpNum(pd.Tr, nd.Tr, ea)
            elseif pd.Tr ~= nil then
                interp.Tr = pd.Tr
            elseif nd.Tr ~= nil then
                interp.Tr = nd.Tr
            end
            
            -- FX
            if pd.Rate ~= nil and nd.Rate ~= nil then
                interp.Rate = self:LerpNum(pd.Rate, nd.Rate, ea)
            elseif pd.Rate ~= nil then
                interp.Rate = pd.Rate
            end
            
            if pd.Bright ~= nil and nd.Bright ~= nil then
                interp.Bright = self:LerpNum(pd.Bright, nd.Bright, ea)
            elseif pd.Bright ~= nil then
                interp.Bright = pd.Bright
            end
            
            if pd.Range ~= nil and nd.Range ~= nil then
                interp.Range = self:LerpNum(pd.Range, nd.Range, ea)
            elseif pd.Range ~= nil then
                interp.Range = pd.Range
            end
            
            result.joints[jn] = interp
        end
    end
    
    return result
end

function Engine:ApplyFrame(fd)
    if not fd then return end
    if not fd.joints then return end
    
    for i = 1, #self.AllJoints do
        local j = self.AllJoints[i]
        if j and self:IsJointValid(j) then
            local d = fd.joints[j.Name]
            if d then
                pcall(function()
                    if j.Type == "Motor6D" then
                        if d.CF then
                            j.Inst.C0 = d.CF
                        end
                    elseif j.Type == "Part" then
                        if d.CF then
                            j.Inst.CFrame = d.CF
                        end
                        if d.SZ and typeof(d.SZ) == "Vector3" then
                            j.Inst.Size = d.SZ
                        end
                        if d.TR ~= nil then
                            j.Inst.Transparency = d.TR
                        end
                        if d.CL then
                            j.Inst.Color = d.CL
                        end
                    elseif j.Type == "GUI" then
                        if d.Pos then
                            j.Inst.Position = d.Pos
                        end
                        if d.Sz then
                            j.Inst.Size = d.Sz
                        end
                        if d.Rot ~= nil then
                            j.Inst.Rotation = d.Rot
                        end
                        if d.Tr ~= nil then
                            j.Inst.BackgroundTransparency = d.Tr
                        end
                    elseif j.Type == "FX" then
                        if d.Rate ~= nil then
                            pcall(function()
                                j.Inst.Rate = d.Rate
                            end)
                        end
                        if d.Bright ~= nil then
                            pcall(function()
                                j.Inst.Brightness = d.Bright
                            end)
                        end
                        if d.Range ~= nil then
                            pcall(function()
                                j.Inst.Range = d.Range
                            end)
                        end
                    end
                end)
            end
        end
    end
end

function Engine:GoTo(time)
    self.CurrentTime = math.max(0, time)
    local fd = self:Evaluate(self.CurrentTime)
    if fd then
        self:ApplyFrame(fd)
    end
end

function Engine:Play()
    if self.IsPlaying then return end
    if #self.Keyframes < 2 then return end
    
    self.IsPlaying = true
    
    local startTick = tick()
    local startTime = self.CurrentTime
    local maxTime = self:GetMaxTime()
    
    -- Limpar conexão anterior
    if self.PlayConn then
        pcall(function()
            self.PlayConn:Disconnect()
        end)
        self.PlayConn = nil
    end
    
    self.PlayConn = RunService.RenderStepped:Connect(function()
        if not self.IsPlaying then
            pcall(function()
                if self.PlayConn then
                    self.PlayConn:Disconnect()
                    self.PlayConn = nil
                end
            end)
            return
        end
        
        local elapsed = (tick() - startTick) * self.Speed
        self.CurrentTime = startTime + elapsed
        
        if self.CurrentTime >= maxTime then
            if self.IsLooping then
                startTick = tick()
                startTime = 0
                self.CurrentTime = 0
            else
                self.CurrentTime = maxTime
                self.IsPlaying = false
                pcall(function()
                    if self.PlayConn then
                        self.PlayConn:Disconnect()
                        self.PlayConn = nil
                    end
                end)
                return
            end
        end
        
        local frameData = self:Evaluate(self.CurrentTime)
        if frameData then
            self:ApplyFrame(frameData)
        end
    end)
end

function Engine:Stop()
    self.IsPlaying = false
    if self.PlayConn then
        pcall(function()
            self.PlayConn:Disconnect()
        end)
        self.PlayConn = nil
    end
end

function Engine:Pause()
    self.IsPlaying = false
end

function Engine:CopyKF()
    for _, kf in ipairs(self.Keyframes) do
        if math.abs(kf.time - self.CurrentTime) < 0.05 then
            self.Clipboard = {joints = {}}
            for n, d in pairs(kf.joints) do
                local dd = {}
                for k, v in pairs(d) do
                    dd[k] = v
                end
                self.Clipboard.joints[n] = dd
            end
            return true
        end
    end
    return false
end

function Engine:PasteKF()
    if not self.Clipboard then return end
    self:PushUndo()
    local kf = {
        time = self.CurrentTime,
        joints = {}
    }
    for n, d in pairs(self.Clipboard.joints) do
        local dd = {}
        for k, v in pairs(d) do
            dd[k] = v
        end
        kf.joints[n] = dd
    end
    
    local newList = {}
    for _, existingKF in ipairs(self.Keyframes) do
        if math.abs(existingKF.time - self.CurrentTime) >= 0.001 then
            table.insert(newList, existingKF)
        end
    end
    self.Keyframes = newList
    
    table.insert(self.Keyframes, kf)
    table.sort(self.Keyframes, function(a, b)
        return a.time < b.time
    end)
end

function Engine:ClearAll()
    self:PushUndo()
    self.Keyframes = {}
end

function Engine:Mirror()
    self:PushUndo()
    for _, kf in ipairs(self.Keyframes) do
        if math.abs(kf.time - self.CurrentTime) < 0.05 then
            for _, d in pairs(kf.joints) do
                if d.CF then
                    pcall(function()
                        local p = d.CF.Position
                        local rx, ry, rz = d.CF:ToEulerAnglesXYZ()
                        if self.MirrorAxis == "X" then
                            d.CF = CFrame.new(-p.X, p.Y, p.Z) *
                                CFrame.Angles(-rx, ry, rz)
                        elseif self.MirrorAxis == "Y" then
                            d.CF = CFrame.new(p.X, -p.Y, p.Z) *
                                CFrame.Angles(rx, -ry, rz)
                        else
                            d.CF = CFrame.new(p.X, p.Y, -p.Z) *
                                CFrame.Angles(rx, ry, -rz)
                        end
                    end)
                end
            end
            break
        end
    end
end

function Engine:Reverse()
    self:PushUndo()
    if #self.Keyframes == 0 then return end
    local mx = self:GetMaxTime()
    for _, kf in ipairs(self.Keyframes) do
        kf.time = mx - kf.time
    end
    table.sort(self.Keyframes, function(a, b)
        return a.time < b.time
    end)
end

function Engine:DupKF(src, dst)
    self:PushUndo()
    for _, kf in ipairs(self.Keyframes) do
        if math.abs(kf.time - src) < 0.05 then
            local nk = {time = dst, joints = {}}
            for n, d in pairs(kf.joints) do
                local dd = {}
                for k, v in pairs(d) do
                    dd[k] = v
                end
                nk.joints[n] = dd
            end
            table.insert(self.Keyframes, nk)
            table.sort(self.Keyframes, function(a, b)
                return a.time < b.time
            end)
            return
        end
    end
end

function Engine:ScaleTime(f)
    self:PushUndo()
    for _, kf in ipairs(self.Keyframes) do
        kf.time = kf.time * f
    end
end

function Engine:AddMarker(t, n)
    table.insert(self.Markers, {
        time = t,
        name = n or "M",
        color = Color3.fromRGB(255, 200, 0)
    })
end

function Engine:ResetPose()
    for _, j in ipairs(self.AllJoints) do
        if self:IsJointValid(j) then
            pcall(function()
                if j.Type == "Motor6D" then
                    j.Inst.C0 = j.OC0
                elseif j.Type == "Part" then
                    j.Inst.CFrame = j.OCF
                elseif j.Type == "GUI" then
                    j.Inst.Position = j.OPos
                    j.Inst.Size = j.OSize
                    j.Inst.Rotation = j.ORot
                end
            end)
        end
    end
end

