local S = _G.S
local E = S.E

-- Deep copy de keyframes
function E.copyKFs()
    local c = {}
    for i,kf in ipairs(E.kfs) do
        local jc = {}
        for k,v in pairs(kf.j) do
            local vc = {} for kk,vv in pairs(v) do vc[kk]=vv end
            jc[k]=vc
        end
        c[i]={t=kf.t,j=jc}
    end
    return c
end

function E.pushU()
    table.insert(E.undos,{kf=E.copyKFs(),time=E.time,spd=E.speed})
    if #E.undos>50 then table.remove(E.undos,1) end
    E.redos={}
end

function E.undo()
    if #E.undos==0 then return end
    table.insert(E.redos,{kf=E.copyKFs(),time=E.time,spd=E.speed})
    local s=table.remove(E.undos) E.kfs=s.kf E.time=s.time E.speed=s.spd
end

function E.redo()
    if #E.redos==0 then return end
    table.insert(E.undos,{kf=E.copyKFs(),time=E.time,spd=E.speed})
    local s=table.remove(E.redos) E.kfs=s.kf E.time=s.time E.speed=s.spd
end

function E.addKF()
    if #E.joints == 0 then 
        print("[Snow] No joints! Select a target first.")
        return 
    end
    
    E.pushU()
    local data = E.snap()
    
    if not data or not next(data) then 
        print("[Snow] Failed to capture pose!")
        return 
    end
    
    -- Remove keyframe existente no mesmo tempo
    local newList = {}
    for _, kf in ipairs(E.kfs) do
        if math.abs(kf.t - E.time) >= 0.001 then 
            table.insert(newList, kf) 
        end
    end
    E.kfs = newList
    
    -- Adiciona novo keyframe
    table.insert(E.kfs, {t = E.time, j = data})
    table.sort(E.kfs, function(a, b) return a.t < b.t end)
    
    print("[Snow] Keyframe added at "..string.format("%.2f", E.time).."s ("..#E.kfs.." total)")
end

function E.removeKF()
    E.pushU()
    local nl={}
    for _,kf in ipairs(E.kfs) do
        if math.abs(kf.t-E.time)>=0.05 then table.insert(nl,kf) end
    end
    E.kfs=nl
end

function E.maxT()
    local m=0
    for _,kf in ipairs(E.kfs) do if kf.t>m then m=kf.t end end
    return math.max(m,0.1)
end

function E.copyKF()
    for _,kf in ipairs(E.kfs) do
        if math.abs(kf.t-E.time)<0.05 then
            E.clip={} for k,v in pairs(kf.j) do
                local vc={} for kk,vv in pairs(v) do vc[kk]=vv end E.clip[k]=vc
            end return true
        end
    end return false
end

function E.pasteKF()
    if not E.clip then return end
    E.pushU()
    local nl={} for _,kf in ipairs(E.kfs) do if math.abs(kf.t-E.time)>=0.001 then table.insert(nl,kf) end end
    E.kfs=nl
    local jc={} for k,v in pairs(E.clip) do local vc={} for kk,vv in pairs(v) do vc[kk]=vv end jc[k]=vc end
    table.insert(E.kfs,{t=E.time,j=jc})
    table.sort(E.kfs,function(a,b) return a.t<b.t end)
end

function E.clearAll() E.pushU() E.kfs={} end

function E.mirror()
    E.pushU()
    for _,kf in ipairs(E.kfs) do
        if math.abs(kf.t-E.time)<0.05 then
            for _,d in pairs(kf.j) do
                if d.cf then pcall(function()
                    local p=d.cf.Position local rx,ry,rz=d.cf:ToEulerAnglesXYZ()
                    if E.mirrorAxis=="X" then d.cf=CFrame.new(-p.X,p.Y,p.Z)*CFrame.Angles(-rx,ry,rz)
                    elseif E.mirrorAxis=="Y" then d.cf=CFrame.new(p.X,-p.Y,p.Z)*CFrame.Angles(rx,-ry,rz)
                    else d.cf=CFrame.new(p.X,p.Y,-p.Z)*CFrame.Angles(rx,ry,-rz) end
                end) end
            end break
        end
    end
end

function E.reverseKFs()
    E.pushU()
    if #E.kfs==0 then return end
    local mx=E.maxT()
    for _,kf in ipairs(E.kfs) do kf.t=mx-kf.t end
    table.sort(E.kfs,function(a,b) return a.t<b.t end)
end

function E.dupKF()
    for _,kf in ipairs(E.kfs) do
        if math.abs(kf.t-E.time)<0.05 then
            E.pushU()
            local jc={} for k,v in pairs(kf.j) do local vc={} for kk,vv in pairs(v) do vc[kk]=vv end jc[k]=vc end
            table.insert(E.kfs,{t=E.time+0.5,j=jc})
            table.sort(E.kfs,function(a,b) return a.t<b.t end) return
        end
    end
end

function E.scaleT(f) E.pushU() for _,kf in ipairs(E.kfs) do kf.t=kf.t*f end end
function E.addMarker() table.insert(E.markers,{t=E.time,name="M"..#E.markers+1}) end

function E.resetPose()
    for _,j in ipairs(E.joints) do
        if E.jValid(j) then pcall(function()
            if j.t=="m6d" then j.inst.C0=j.origC0
            elseif j.t=="part" then j.inst.CFrame=j.origCF
            elseif j.t=="gui" then j.inst.Position=j.oP j.inst.Size=j.oS j.inst.Rotation=j.oR end
        end) end
    end
end

-- EVALUATE: interpola entre keyframes
function E.eval(time)
    local n=#E.kfs
    if n==0 then return nil end
    if n==1 then return E.kfs[1].j end
    local p,nx=nil,nil
    for i=1,n do
        if E.kfs[i].t<=time then p=E.kfs[i] end
        if E.kfs[i].t>=time and nx==nil then nx=E.kfs[i] end
    end
    if not p then p=E.kfs[1] end
    if not nx then nx=E.kfs[n] end
    if p==nx then return p.j end
    local diff=nx.t-p.t
    if diff<=0 then return p.j end
    local raw=math.clamp((time-p.t)/diff,0,1)
    local result={}
    local all={} for k in pairs(p.j) do all[k]=true end for k in pairs(nx.j) do all[k]=true end
    for k in pairs(all) do
        local a,b=p.j[k],nx.j[k]
        if a and not b then result[k]=a
        elseif b and not a then result[k]=b
        elseif a and b then
            local ea=E.ease(raw,b.es or "Linear",b.ed or "InOut")
            local r={es=b.es,ed=b.ed}
            if a.cf and b.cf then r.cf=E.lCF(a.cf,b.cf,ea) end
            if a.sz and b.sz then
                if typeof(a.sz)=="Vector3" then r.sz=E.lV3(a.sz,b.sz,ea)
                elseif typeof(a.sz)=="UDim2" then r.sz=E.lU2(a.sz,b.sz,ea) end
            end
            if a.tr~=nil and b.tr~=nil then r.tr=E.lN(a.tr,b.tr,ea) end
            if a.cl and b.cl then r.cl=E.lC3(a.cl,b.cl,ea) end
            if a.pos and b.pos then r.pos=E.lU2(a.pos,b.pos,ea) end
            if a.rot~=nil and b.rot~=nil then r.rot=E.lN(a.rot,b.rot,ea) end
            result[k]=r
        end
    end
    return result
end

-- APPLY: aplica dados nos joints (SEM mover camera)
-- Substitua a função E.apply por:

function E.apply(data)
    if not data then return end
    
    for _,j in ipairs(E.joints) do
        if not E.jValid(j) then continue end
        
        local d = data[j.name]
        if not d then continue end
        
        pcall(function()
            if j.t == "m6d" then
                -- Motor6D: só mexe no C0
                if d.cf and typeof(d.cf) == "CFrame" then
                    j.inst.C0 = d.cf
                end
            elseif j.t == "part" then
                -- Part solta (não do character local)
                if not E.isLocalChar(j.inst) then
                    if d.cf and typeof(d.cf) == "CFrame" then
                        j.inst.CFrame = d.cf
                    end
                    if d.sz and typeof(d.sz) == "Vector3" then
                        j.inst.Size = d.sz
                    end
                    if d.tr ~= nil then
                        j.inst.Transparency = d.tr
                    end
                    if d.cl and typeof(d.cl) == "Color3" then
                        j.inst.Color = d.cl
                    end
                end
            elseif j.t == "gui" then
                if d.pos then j.inst.Position = d.pos end
                if d.sz then j.inst.Size = d.sz end
                if d.rot ~= nil then j.inst.Rotation = d.rot end
                if d.tr ~= nil then j.inst.BackgroundTransparency = d.tr end
            end
        end)
    end
end

function E.goTo(t) E.time=math.max(0,t) local d=E.eval(E.time) if d then E.apply(d) end end

-- Substitua a função E.play por:

function E.play()
    if E.playing then return end
    if #E.kfs < 1 then 
        print("[Snow] No keyframes to play!") 
        return 
    end
    if #E.joints == 0 then
        print("[Snow] No joints! Select a target first.")
        return
    end
    
    E.playing = true
    local startTick = tick()
    local startTime = E.time
    local maxTime = E.maxT()
    
    -- Desconecta conexão anterior
    if E.conn then 
        pcall(function() E.conn:Disconnect() end) 
        E.conn = nil 
    end
    
    E.conn = S.RS.Heartbeat:Connect(function()
        if not E.playing then
            if E.conn then 
                pcall(function() E.conn:Disconnect() end) 
                E.conn = nil 
            end
            return
        end
        
        local elapsed = (tick() - startTick) * E.speed
        E.time = startTime + elapsed
        
        if E.time >= maxTime then
            if E.looping then
                startTick = tick()
                startTime = 0
                E.time = 0
            else
                E.time = maxTime
                E.playing = false
                if E.conn then 
                    pcall(function() E.conn:Disconnect() end) 
                    E.conn = nil 
                end
            end
        end
        
        -- Avalia e aplica
        local data = E.eval(E.time)
        if data then 
            E.apply(data) 
        end
    end)
    
    print("[Snow] Playing animation...")
end

function E.stop()
    E.playing=false
    if E.conn then pcall(function() E.conn:Disconnect() end) E.conn=nil end
end
function E.pause() E.playing=false end

