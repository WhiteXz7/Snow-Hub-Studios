-- Easing
function E.bounce(t)
    if t<1/2.75 then return 7.5625*t*t
    elseif t<2/2.75 then t=t-1.5/2.75 return 7.5625*t*t+.75
    elseif t<2.5/2.75 then t=t-2.25/2.75 return 7.5625*t*t+.9375
    else t=t-2.625/2.75 return 7.5625*t*t+.984375 end
end

function E.ease(a,s,d)
    if not s or s=="Linear" then return a end
    if s=="Constant" then return a>=1 and 1 or 0 end
    local function ei(t)
        if s=="Quad" then return t*t
        elseif s=="Cubic" then return t*t*t
        elseif s=="Quart" then return t^4
        elseif s=="Quint" then return t^5
        elseif s=="Sine" then return 1-math.cos(t*math.pi/2)
        elseif s=="Expo" then return t==0 and 0 or 2^(10*(t-1))
        elseif s=="Circ" then return 1-math.sqrt(math.max(0,1-t*t))
        elseif s=="Back" then return t*t*(2.70158*t-1.70158)
        elseif s=="Elastic" then
            if t==0 or t==1 then return t end
            return -2^(10*(t-1))*math.sin((t-1.1)*5*math.pi)
        elseif s=="Bounce" then return 1-E.bounce(1-t)
        end return t
    end
    local function eo(t)
        if s=="Bounce" then return E.bounce(t) end
        return 1-ei(1-t)
    end
    d=d or "InOut"
    if d=="In" then return ei(a)
    elseif d=="Out" then return eo(a)
    else return a<.5 and ei(a*2)/2 or .5+eo((a-.5)*2)/2 end
end

-- Lerps seguros
function E.lCF(a,b,t) local o,r=pcall(function() return a:Lerp(b,t) end) return o and r or a end
function E.lV3(a,b,t) local o,r=pcall(function() return a:Lerp(b,t) end) return o and r or a end
function E.lN(a,b,t) return a+(b-a)*t end
function E.lC3(a,b,t) return Color3.new(a.R+(b.R-a.R)*t,a.G+(b.G-a.G)*t,a.B+(b.B-a.B)*t) end
function E.lU2(a,b,t) return UDim2.new(a.X.Scale+(b.X.Scale-a.X.Scale)*t,a.X.Offset+(b.X.Offset-a.X.Offset)*t,a.Y.Scale+(b.Y.Scale-a.Y.Scale)*t,a.Y.Offset+(b.Y.Offset-a.Y.Offset)*t) end

function E.jValid(j)
    if not j or not j.inst then return false end
    local o,r=pcall(function() return j.inst.Parent~=nil end)
    return o and r
end

-- É part do character local? Se sim, NÃO mover CFrame
function E.isLocalChar(inst)
    local char = S.LP.Character
    if not char then return false end
    return inst:IsDescendantOf(char)
end

-- Substitua a função E.scan por:

function E.scan(tgt)
    E.joints = {}
    E.target = tgt
    if not tgt then return end
    
    local motorParts = {}
    
    -- Primeiro: Motor6D (para rigs)
    for _,c in ipairs(tgt:GetDescendants()) do
        pcall(function()
            if c:IsA("Motor6D") and c.Part0 and c.Part1 and c.Parent then
                table.insert(E.joints, {
                    t="m6d", 
                    inst=c, 
                    name=c.Name,
                    origC0=c.C0:Clone(), 
                    origC1=c.C1:Clone()
                })
                motorParts[c.Part0] = true
                motorParts[c.Part1] = true
            end
        end)
    end
    
    -- Segundo: Parts soltas (não conectadas por Motor6D e não do char local)
    for _,c in ipairs(tgt:GetDescendants()) do
        pcall(function()
            if c:IsA("BasePart") and not c:IsA("Terrain") and not motorParts[c] then
                if not E.isLocalChar(c) then
                    table.insert(E.joints, {
                        t="part", 
                        inst=c, 
                        name=c.Name.."_"..tostring(c:GetDebugId()):sub(1,4),
                        origCF=c.CFrame:Clone()
                    })
                end
            end
        end)
    end
    
    -- Se target é uma BasePart solta
    if tgt:IsA("BasePart") and not E.isLocalChar(tgt) then
        local found = false
        for _,j in ipairs(E.joints) do 
            if j.inst == tgt then 
                found = true 
                break 
            end 
        end
        if not found then
            table.insert(E.joints, {
                t="part",
                inst=tgt,
                name=tgt.Name.."_root",
                origCF=tgt.CFrame:Clone()
            })
        end
    end
    
    print("[Snow] Scanned: "..#E.joints.." joints in "..tgt.Name)
end

-- Captura estado atual dos joints
function E.snap()
    local d = {}
    for _,j in ipairs(E.joints) do
        if E.jValid(j) then
            pcall(function()
                if j.t=="m6d" then
                    d[j.name]={cf=j.inst.C0, es=E.interp, ed=E.eDir}
                elseif j.t=="part" then
                    d[j.name]={cf=j.inst.CFrame, sz=j.inst.Size,
                        tr=j.inst.Transparency, cl=j.inst.Color,
                        es=E.interp, ed=E.eDir}
                elseif j.t=="gui" then
                    d[j.name]={pos=j.inst.Position, sz=j.inst.Size,
                        rot=j.inst.Rotation, tr=j.inst.BackgroundTransparency,
                        es=E.interp, ed=E.eDir}
                end
            end)
        end
    end
    return d
end

