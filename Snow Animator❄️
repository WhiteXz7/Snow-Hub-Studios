local E = S.E

-- ══════════════════════════════════════
-- UNDO / REDO SYSTEM
-- ══════════════════════════════════════

function E.copyKFs()
    local c = {}
    for i, kf in ipairs(E.kfs) do
        local jc = {}
        for k, v in pairs(kf.j) do
            local vc = {}
            for kk, vv in pairs(v) do
                vc[kk] = vv
            end
            jc[k] = vc
        end
        c[i] = {t = kf.t, j = jc}
    end
    return c
end

function E.pushU()
    table.insert(E.undos, {kf = E.copyKFs(), time = E.time, spd = E.speed})
    if #E.undos > 50 then table.remove(E.undos, 1) end
    E.redos = {}
end

function E.undo()
    if #E.undos == 0 then return end
    table.insert(E.redos, {kf = E.copyKFs(), time = E.time, spd = E.speed})
    local s = table.remove(E.undos)
    E.kfs = s.kf
    E.time = s.time
    E.speed = s.spd
end

function E.redo()
    if #E.redos == 0 then return end
    table.insert(E.undos, {kf = E.copyKFs(), time = E.time, spd = E.speed})
    local s = table.remove(E.redos)
    E.kfs = s.kf
    E.time = s.time
    E.speed = s.spd
end

-- ══════════════════════════════════════
-- KEYFRAME OPERATIONS
-- ══════════════════════════════════════

function E.addKF()
    if #E.joints == 0 then
        print("[Snow] ❌ No joints! Select a target first.")
        return
    end
    
    E.pushU()
    local data = E.snap()
    
    if not data or not next(data) then
        print("[Snow] ❌ Failed to capture pose!")
        return
    end
    
    -- Remove existing keyframe at same time
    local newList = {}
    for _, kf in ipairs(E.kfs) do
        if math.abs(kf.t - E.time) >= 0.001 then
            table.insert(newList, kf)
        end
    end
    E.kfs = newList
    
    -- Add new keyframe
    table.insert(E.kfs, {t = E.time, j = data})
    table.sort(E.kfs, function(a, b) return a.t < b.t end)
    
    print("[Snow] ✅ Keyframe added at " .. string.format("%.2f", E.time) .. "s (" .. #E.kfs .. " total)")
end

function E.removeKF()
    E.pushU()
    local newList = {}
    for _, kf in ipairs(E.kfs) do
        if math.abs(kf.t - E.time) >= 0.05 then
            table.insert(newList, kf)
        end
    end
    E.kfs = newList
    print("[Snow] 🗑️ Keyframe removed")
end

function E.maxT()
    local m = 0
    for _, kf in ipairs(E.kfs) do
        if kf.t > m then m = kf.t end
    end
    return math.max(m, 0.1)
end

function E.copyKF()
    for _, kf in ipairs(E.kfs) do
        if math.abs(kf.t - E.time) < 0.05 then
            E.clip = {}
            for k, v in pairs(kf.j) do
                local vc = {}
                for kk, vv in pairs(v) do
                    vc[kk] = vv
                end
                E.clip[k] = vc
            end
            print("[Snow] 📋 Keyframe copied")
            return true
        end
    end
    return false
end

function E.pasteKF()
    if not E.clip then
        print("[Snow] ❌ Nothing to paste")
        return
    end
    E.pushU()
    local newList = {}
    for _, kf in ipairs(E.kfs) do
        if math.abs(kf.t - E.time) >= 0.001 then
            table.insert(newList, kf)
        end
    end
    E.kfs = newList
    local jc = {}
    for k, v in pairs(E.clip) do
        local vc = {}
        for kk, vv in pairs(v) do
            vc[kk] = vv
        end
        jc[k] = vc
    end
    table.insert(E.kfs, {t = E.time, j = jc})
    table.sort(E.kfs, function(a, b) return a.t < b.t end)
    print("[Snow] 📋 Keyframe pasted")
end

function E.clearAll()
    E.pushU()
    E.kfs = {}
    print("[Snow] 🗑️ All keyframes cleared")
end

function E.mirror()
    E.pushU()
    for _, kf in ipairs(E.kfs) do
        if math.abs(kf.t - E.time) < 0.05 then
            for _, d in pairs(kf.j) do
                if d.cf then
                    pcall(function()
                        local p = d.cf.Position
                        local rx, ry, rz = d.cf:ToEulerAnglesXYZ()
                        if E.mirrorAxis == "X" then
                            d.cf = CFrame.new(-p.X, p.Y, p.Z) * CFrame.Angles(-rx, ry, rz)
                        elseif E.mirrorAxis == "Y" then
                            d.cf = CFrame.new(p.X, -p.Y, p.Z) * CFrame.Angles(rx, -ry, rz)
                        else
                            d.cf = CFrame.new(p.X, p.Y, -p.Z) * CFrame.Angles(rx, ry, -rz)
                        end
                    end)
                end
            end
            print("[Snow] 🪞 Mirrored on " .. E.mirrorAxis)
            break
        end
    end
end

function E.reverseKFs()
    E.pushU()
    if #E.kfs == 0 then return end
    local mx = E.maxT()
    for _, kf in ipairs(E.kfs) do
        kf.t = mx - kf.t
    end
    table.sort(E.kfs, function(a, b) return a.t < b.t end)
    print("[Snow] ⏪ Animation reversed")
end

function E.dupKF()
    for _, kf in ipairs(E.kfs) do
        if math.abs(kf.t - E.time) < 0.05 then
            E.pushU()
            local jc = {}
            for k, v in pairs(kf.j) do
                local vc = {}
                for kk, vv in pairs(v) do
                    vc[kk] = vv
                end
                jc[k] = vc
            end
            table.insert(E.kfs, {t = E.time + 0.5, j = jc})
            table.sort(E.kfs, function(a, b) return a.t < b.t end)
            print("[Snow] 📑 Keyframe duplicated")
            return
        end
    end
end

function E.scaleT(f)
    E.pushU()
    for _, kf in ipairs(E.kfs) do
        kf.t = kf.t * f
    end
    print("[Snow] ⏱️ Time scaled by " .. f .. "x")
end

function E.addMarker()
    table.insert(E.markers, {t = E.time, name = "M" .. (#E.markers + 1)})
    print("[Snow] 📌 Marker added")
end

function E.resetPose()
    for _, j in ipairs(E.joints) do
        if E.jValid(j) then
            pcall(function()
                if j.t == "m6d" then
                    j.inst.C0 = j.origC0
                    j.inst.C1 = j.origC1
                elseif j.t == "bone" then
                    j.inst.CFrame = j.origCF
                    j.inst.Transform = j.origTrans
                elseif j.t == "part" then
                    j.inst.CFrame = j.origCF
                    j.inst.Size = j.origSize
                    j.inst.Color = j.origColor
                    j.inst.Transparency = j.origTrans
                elseif j.t == "gui" then
                    j.inst.Position = j.oP
                    j.inst.Size = j.oS
                    j.inst.Rotation = j.oR
                elseif j.t == "light" then
                    j.inst.Brightness = j.origBright
                    j.inst.Color = j.origColor
                    j.inst.Enabled = j.origEnabled
                elseif j.t == "particle" then
                    j.inst.Enabled = j.origEnabled
                    j.inst.Rate = j.origRate
                elseif j.t == "sound" then
                    j.inst.Volume = j.origVol
                    j.inst.PlaybackSpeed = j.origPitch
                elseif j.t == "mesh" then
                    j.inst.Scale = j.origScale
                    j.inst.Offset = j.origOffset
                end
            end)
        end
    end
    print("[Snow] 🔄 Pose reset")
end

-- ══════════════════════════════════════
-- EVALUATION (Interpolates between keyframes)
-- ══════════════════════════════════════

function E.eval(time)
    local n = #E.kfs
    if n == 0 then return nil end
    if n == 1 then return E.kfs[1].j end
    
    local p, nx = nil, nil
    for i = 1, n do
        if E.kfs[i].t <= time then p = E.kfs[i] end
        if E.kfs[i].t >= time and nx == nil then nx = E.kfs[i] end
    end
    
    if not p then p = E.kfs[1] end
    if not nx then nx = E.kfs[n] end
    if p == nx then return p.j end
    
    local diff = nx.t - p.t
    if diff <= 0 then return p.j end
    
    local raw = math.clamp((time - p.t) / diff, 0, 1)
    local result = {}
    
    local all = {}
    for k in pairs(p.j) do all[k] = true end
    for k in pairs(nx.j) do all[k] = true end
    
    for k in pairs(all) do
        local a, b = p.j[k], nx.j[k]
        
        if a and not b then
            result[k] = a
        elseif b and not a then
            result[k] = b
        elseif a and b then
            local ea = E.ease(raw, b.es or "Linear", b.ed or "InOut")
            local r = {es = b.es, ed = b.ed}
            
            -- CFrame
            if a.cf and b.cf then r.cf = E.lCF(a.cf, b.cf, ea) end
            if a.c1 and b.c1 then r.c1 = E.lCF(a.c1, b.c1, ea) end
            if a.trans and b.trans then r.trans = E.lCF(a.trans, b.trans, ea) end
            
            -- Size (Vector3 or UDim2)
            if a.sz and b.sz then
                if typeof(a.sz) == "Vector3" then
                    r.sz = E.lV3(a.sz, b.sz, ea)
                elseif typeof(a.sz) == "UDim2" then
                    r.sz = E.lU2(a.sz, b.sz, ea)
                end
            end
            
            -- Numbers
            if a.tr ~= nil and b.tr ~= nil then r.tr = E.lN(a.tr, b.tr, ea) end
            if a.rot ~= nil and b.rot ~= nil then r.rot = E.lN(a.rot, b.rot, ea) end
            if a.bright ~= nil and b.bright ~= nil then r.bright = E.lN(a.bright, b.bright, ea) end
            if a.range ~= nil and b.range ~= nil then r.range = E.lN(a.range, b.range, ea) end
            if a.angle ~= nil and b.angle ~= nil then r.angle = E.lN(a.angle, b.angle, ea) end
            if a.rate ~= nil and b.rate ~= nil then r.rate = E.lN(a.rate, b.rate, ea) end
            if a.vol ~= nil and b.vol ~= nil then r.vol = E.lN(a.vol, b.vol, ea) end
            if a.pitch ~= nil and b.pitch ~= nil then r.pitch = E.lN(a.pitch, b.pitch, ea) end
            if a.w0 ~= nil and b.w0 ~= nil then r.w0 = E.lN(a.w0, b.w0, ea) end
            if a.w1 ~= nil and b.w1 ~= nil then r.w1 = E.lN(a.w1, b.w1, ea) end
            if a.life ~= nil and b.life ~= nil then r.life = E.lN(a.life, b.life, ea) end
            
            -- Colors
            if a.cl and b.cl then r.cl = E.lC3(a.cl, b.cl, ea) end
            
            -- UDim2
            if a.pos and b.pos then r.pos = E.lU2(a.pos, b.pos, ea) end
            
            -- Vector3
            if a.scale and b.scale then r.scale = E.lV3(a.scale, b.scale, ea) end
            if a.offset and b.offset then r.offset = E.lV3(a.offset, b.offset, ea) end
            
            -- Booleans (snap at halfway)
            if a.enabled ~= nil and b.enabled ~= nil then
                r.enabled = ea >= 0.5 and b.enabled or a.enabled
            end
            
            result[k] = r
        end
    end
    
    return result
end

-- ══════════════════════════════════════
-- APPLY (Applies interpolated data to joints)
-- ══════════════════════════════════════

function E.apply(data)
    if not data then return end
    
    for _, j in ipairs(E.joints) do
        local d = data[j.name]
        if d and E.jValid(j) then
            pcall(function()
                if j.t == "m6d" then
                    if d.cf then j.inst.C0 = d.cf end
                    if d.c1 then j.inst.C1 = d.c1 end
                    
                elseif j.t == "bone" then
                    if d.cf then j.inst.CFrame = d.cf end
                    if d.trans then j.inst.Transform = d.trans end
                    
                elseif j.t == "part" then
                    if not E.isLocalChar(j.inst) then
                        if d.cf then j.inst.CFrame = d.cf end
                        if d.sz and typeof(d.sz) == "Vector3" then j.inst.Size = d.sz end
                        if d.tr ~= nil then j.inst.Transparency = d.tr end
                        if d.cl then j.inst.Color = d.cl end
                    end
                    
                elseif j.t == "gui" then
                    if d.pos then j.inst.Position = d.pos end
                    if d.sz then j.inst.Size = d.sz end
                    if d.rot ~= nil then j.inst.Rotation = d.rot end
                    if d.tr ~= nil then j.inst.BackgroundTransparency = d.tr end
                    if d.cl then j.inst.BackgroundColor3 = d.cl end
                    
                elseif j.t == "light" then
                    if d.bright ~= nil then j.inst.Brightness = d.bright end
                    if d.cl then j.inst.Color = d.cl end
                    if d.enabled ~= nil then j.inst.Enabled = d.enabled end
                    if d.range ~= nil and j.inst:IsA("PointLight") then j.inst.Range = d.range end
                    if d.angle ~= nil and j.inst:IsA("SpotLight") then j.inst.Angle = d.angle end
                    
                elseif j.t == "particle" then
                    if d.enabled ~= nil then j.inst.Enabled = d.enabled end
                    if d.rate ~= nil then j.inst.Rate = d.rate end
                    
                elseif j.t == "sound" then
                    if d.vol ~= nil then j.inst.Volume = d.vol end
                    if d.pitch ~= nil then j.inst.PlaybackSpeed = d.pitch end
                    
                elseif j.t == "mesh" then
                    if d.scale then j.inst.Scale = d.scale end
                    if d.offset then j.inst.Offset = d.offset end
                    
                elseif j.t == "beam" then
                    if d.enabled ~= nil then j.inst.Enabled = d.enabled end
                    if d.w0 ~= nil then j.inst.Width0 = d.w0 end
                    if d.w1 ~= nil then j.inst.Width1 = d.w1 end
                    
                elseif j.t == "trail" then
                    if d.enabled ~= nil then j.inst.Enabled = d.enabled end
                    if d.life ~= nil then j.inst.Lifetime = d.life end
                end
            end)
        end
    end
end

-- ══════════════════════════════════════
-- PLAYBACK
-- ══════════════════════════════════════

function E.goTo(t)
    E.time = math.max(0, t)
    local d = E.eval(E.time)
    if d then E.apply(d) end
end

function E.play()
    if E.playing then return end
    if #E.kfs < 1 then
        print("[Snow] ❌ No keyframes to play!")
        return
    end
    if #E.joints == 0 then
        print("[Snow] ❌ No joints! Select a target first.")
        return
    end
    
    E.playing = true
    local startTick = tick()
    local startTime = E.time
    local maxTime = E.maxT()
    
    if E.conn then
        pcall(function() E.conn:Disconnect() end)
        E.conn = nil
    end
    
    print("[Snow] ▶️ Playing animation...")
    
    E.conn = S.RS.Heartbeat:Connect(function()
        if not E.playing then
            if E.conn then
                pcall(function() E.conn:Disconnect() end)
                E.conn = nil
            end
            return
        end
        
        local elapsed = (tick() - startTick) * E.speed
        E.time = startTime + elapsed
        
        if E.time >= maxTime then
            if E.looping then
                startTick = tick()
                startTime = 0
                E.time = 0
            else
                E.time = maxTime
                E.playing = false
                print("[Snow] ⏹️ Animation finished")
                if E.conn then
                    pcall(function() E.conn:Disconnect() end)
                    E.conn = nil
                end
            end
        end
        
        local data = E.eval(E.time)
        if data then E.apply(data) end
    end)
end

function E.stop()
    E.playing = false
    if E.conn then
        pcall(function() E.conn:Disconnect() end)
        E.conn = nil
    end
    print("[Snow] ⏹️ Stopped")
end

function E.pause()
    E.playing = false
    print("[Snow] ⏸️ Paused")
end

