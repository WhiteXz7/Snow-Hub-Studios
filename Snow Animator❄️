]]
local SAP = _G.SAP
local E = SAP.E
local C = SAP.C
local New = SAP.New

-- MAIN UPDATE LOOP
local uc = 0
SAP.RS.RenderStepped:Connect(function(dt)
    uc = uc + 1
    if uc % 2 == 0 then
        pcall(SAP.updateTL)
        pcall(function() SAP.spdL.Text=string.format("%.1fx",E.speed) end)
        pcall(function() if not E.playing then SAP.playBtn.Text="▶" SAP.playBtn.BackgroundColor3=C.green end end)
        pcall(function() SAP.fpsL.Text=tostring(math.floor(1/dt)) end)
    end
end)

-- AUTO KEY
local lastSt = {}
spawn(function()
    while SAP.SG and SAP.SG.Parent do
        if E.autoKey and #E.joints>0 and not E.playing then
            local changed = false
            for _,j in ipairs(E.joints) do
                pcall(function()
                    if j.t=="m6d" and j.inst and j.inst.Parent then
                        local c=tostring(j.inst.C0)
                        if lastSt[j.name] and lastSt[j.name]~=c then changed=true end
                        lastSt[j.name]=c
                    elseif j.t=="part" and j.inst and j.inst.Parent then
                        local c=tostring(j.inst.CFrame)
                        if lastSt[j.name] and lastSt[j.name]~=c then changed=true end
                        lastSt[j.name]=c
                    end
                end)
            end
            if changed then E.addKF() end
        end
        wait(0.2)
    end
end)

-- UPDATE JOINT LIST WHEN TARGET CHANGES
spawn(function()
    local lt=nil
    while SAP.SG and SAP.SG.Parent do
        if E.target~=lt then lt=E.target pcall(SAP.updateJoints) end
        wait(0.4)
    end
end)

-- KEYBOARD SHORTCUTS
SAP.UIS.InputBegan:Connect(function(inp,gp)
    if gp then return end
    local k=inp.KeyCode
    if k==Enum.KeyCode.Space then
        if E.tweenMode then
            if E.playing then E.stop() else E.tweenPlay() end
        else
            if E.playing then E.pause() else E.play() end
        end
    elseif k==Enum.KeyCode.K then E.addKF()
    elseif k==Enum.KeyCode.Z and SAP.UIS:IsKeyDown(Enum.KeyCode.LeftControl) then
        if SAP.UIS:IsKeyDown(Enum.KeyCode.LeftShift) then E.redo() E.goTo(E.time) else E.undo() E.goTo(E.time) end
    elseif k==Enum.KeyCode.C and SAP.UIS:IsKeyDown(Enum.KeyCode.LeftControl) then E.copyKF()
    elseif k==Enum.KeyCode.V and SAP.UIS:IsKeyDown(Enum.KeyCode.LeftControl) then E.pasteKF()
    elseif k==Enum.KeyCode.Delete then E.removeKF()
    elseif k==Enum.KeyCode.Left then E.time=math.max(0,E.time-1/E.fps) E.goTo(E.time)
    elseif k==Enum.KeyCode.Right then E.time=E.time+1/E.fps E.goTo(E.time)
    elseif k==Enum.KeyCode.Home then E.goTo(0)
    elseif k==Enum.KeyCode.End then E.goTo(E.maxTime())
    end
end)

